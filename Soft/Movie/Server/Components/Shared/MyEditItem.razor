@* Generic reusable component for edit forms - automatically selects the right input component based on type *@
@using System.Linq.Expressions
@typeparam TValue

<div class="mb-3">
    <label for="@FieldId" class="form-label">@Label:</label>

    @if (typeof(TValue) == typeof(string) || Nullable.GetUnderlyingType(typeof(TValue)) == typeof(string))
    {
        <InputText id="@FieldId" Value="@(Value as string)" ValueChanged="@OnValueChanged" ValueExpression="@(() => (string)(object)Value!)" class="form-control" />
    }
    else if (typeof(TValue) == typeof(DateOnly) || Nullable.GetUnderlyingType(typeof(TValue)) == typeof(DateOnly))
    {
        <InputDate id="@FieldId" Value="@Value" ValueChanged="@ValueChanged" ValueExpression="@ValueExpression" class="form-control" TValue="TValue" />
    }
    else if (typeof(TValue) == typeof(DateTime) || Nullable.GetUnderlyingType(typeof(TValue)) == typeof(DateTime))
    {
        <InputDate id="@FieldId" Value="@Value" ValueChanged="@ValueChanged" ValueExpression="@ValueExpression" class="form-control" TValue="TValue" />
    }
    else if (IsNumericType(typeof(TValue)))
    {
        <InputNumber id="@FieldId" Value="@Value" ValueChanged="@ValueChanged" ValueExpression="@ValueExpression" class="form-control" TValue="TValue" />
    }
    else if (typeof(TValue) == typeof(bool) || Nullable.GetUnderlyingType(typeof(TValue)) == typeof(bool))
    {
        var boolValue = (bool)(object)Value!;
        <InputCheckbox id="@FieldId" Value="@boolValue" ValueChanged="@OnBoolValueChanged" ValueExpression="@(() => (bool)(object)Value!)" class="form-check-input" />
    }
    else
    {
        <p class="text-warning">Unsupported type: @typeof(TValue).Name</p>
    }

    <ValidationMessage For="ValueExpression" class="text-danger" />
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string FieldId { get; set; } = string.Empty;
    [Parameter] public TValue Value { get; set; } = default!;
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    [Parameter] public Expression<Func<TValue>> ValueExpression { get; set; } = default!;

    private Task OnValueChanged(string? value)
    {
        return ValueChanged.InvokeAsync((TValue)(object)value!);
    }

    private Task OnBoolValueChanged(bool value)
    {
        return ValueChanged.InvokeAsync((TValue)(object)value);
    }

    /// <summary>
    /// Check if the type is a numeric type (int, decimal, double, etc.)
    /// </summary>
    private static bool IsNumericType(Type type)
    {
        type = Nullable.GetUnderlyingType(type) ?? type;
        return type == typeof(int) || 
               type == typeof(long) || 
               type == typeof(decimal) || 
               type == typeof(double) || 
               type == typeof(float) || 
               type == typeof(short) || 
               type == typeof(byte);
    }
}

