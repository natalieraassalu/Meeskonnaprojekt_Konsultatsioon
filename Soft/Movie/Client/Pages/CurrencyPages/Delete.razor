@page "/currencies/delete"
@using Abc.Data
@using Abc.Infra
@attribute [ExcludeFromInteractiveRouting]
@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete Currency" 
              EntityTitle="Currency" 
              Entity="item" 
              BasePath="/currencies" 
              OnValidSubmit="delete" />

@code {
    private Currency item;

    [SupplyParameterFromQuery] private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        item = await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }

    private async Task delete()
    {
        await repo.DeleteAsync(item.Id);
        NavigationManager.NavigateTo("/currencies");
    }
}
