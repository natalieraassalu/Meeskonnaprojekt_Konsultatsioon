@using System.Reflection

<Router AppAssembly="typeof(Program).Assembly"
        AdditionalAssemblies="new[] { typeof(Abc.Soft.ConsApp.Client.RedirectToLogin).Assembly }">
    <Found Context="routeData">
        @if (IsPublicPage(routeData))
        {
            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        }
        else
        {
            <AuthorizeView>
                <Authorized>
                    <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
                </Authorized>
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeView>
        }
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <Pages.NotFound />
        </LayoutView>
    </NotFound>
</Router>

@code {
    // Login and Register are the only pages visitors can open without signing in.
    private static bool IsPublicPage(RouteData routeData)
    {
        return routeData.PageType == typeof(Account.Pages.Login)
            || routeData.PageType == typeof(Account.Pages.Register);
    }
}
