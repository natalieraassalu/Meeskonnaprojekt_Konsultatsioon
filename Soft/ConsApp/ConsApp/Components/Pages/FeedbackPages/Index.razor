@page "/feedbacks"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Feedbacks</PageTitle>

<h1>Feedbacks</h1>

<p>
    <a href="feedbacks/create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>BookingId</th>
            <th>Rating</th>
            <th>Comment</th>
            <th>CreatedAt</th>
            <th>ValidFrom</th>
            <th>ValidTo</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var feedback in feedbacks)
        {
            <tr>
                <td>@feedback.BookingId</td>
                <td>@feedback.Rating</td>
                <td>@feedback.Comment</td>
                <td>@feedback.CreatedAt</td>
                <td>@feedback.ValidFrom</td>
                <td>@feedback.ValidTo</td>
                <td>
                    <a href="@($"feedbacks/edit?id={feedback.Id}")">Edit</a> |
                    <a href="@($"feedbacks/details?id={feedback.Id}")">Details</a> |
                    <a href="@($"feedbacks/delete?id={feedback.Id}")">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Feedback> feedbacks = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        feedbacks = await context.Feedback.ToListAsync();
    }
}
