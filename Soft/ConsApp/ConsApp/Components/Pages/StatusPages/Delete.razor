@page "/statuses/delete"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Status</h2>
    <hr />
    @if (status is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@status.Name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Code</dt>
            <dd class="col-sm-10">@status.Code</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Details</dt>
            <dd class="col-sm-10">@status.Details</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ValidFrom</dt>
            <dd class="col-sm-10">@status.ValidFrom</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ValidTo</dt>
            <dd class="col-sm-10">@status.ValidTo</dd>
        </dl>
        <EditForm method="post" Model="status" OnValidSubmit="DeleteStatus" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(status is null)">Delete</button> |
            <a href="/statuses">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Status? status;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        status = await context.Statuses.FirstOrDefaultAsync(m => m.Id == Id);

        if (status is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteStatus()
    {
        using var context = DbFactory.CreateDbContext();
        context.Statuses.Remove(status!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/statuses");
    }
}
