@page "/materials/delete"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Material</PageTitle>

<h1>Delete Material</h1>
<h3>Are you sure you want to delete this material?</h3>
<hr />

@if (material is null)
{
    <p>Loading...</p>
}
else
{
    @* Show the material's data so the user can confirm what they're deleting. *@
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@material.Name</dd>
        
        <dt class="col-sm-2">Author</dt>
        <dd class="col-sm-10">@material.Author</dd>

        <dt class="col-sm-2">Number</dt>
        <dd class="col-sm-10">@material.Number</dd>

        <dt class="col-sm-2">Details</dt>
        <dd class="col-sm-10">@material.Details</dd>
    </dl>

    <button class="btn btn-danger" @onclick="DeleteMaterial">Delete</button>
    <a href="/materials" class="btn btn-secondary">Cancel</a>
}

@code {
    // The material Id comes from the URL like /materials/delete?id=...
    [SupplyParameterFromQuery] public Guid Id { get; set; }

    // The material we are about to delete.
    private Material? material;

    protected override async Task OnInitializedAsync()
    {
        // Load the material from the database so we can show its data.
        using var context = DbFactory.CreateDbContext();
        material = await context.Material.FirstOrDefaultAsync(m => m.Id == Id);
    }

    private async Task DeleteMaterial()
    {
        if (material is null) return;

        // Remove the material from the database.
        using var context = DbFactory.CreateDbContext();
        context.Material.Remove(material);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/materials");
    }
}
