@page "/materials/create"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Material</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Material" OnValidSubmit="AddMaterial" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <label for="name" class="form-label">Name:</label> 
                <InputText id="name" @bind-Value="Material.Name" class="form-control" /> 
                <ValidationMessage For="() => Material.Name" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="code" class="form-label">Code:</label> 
                <InputText id="code" @bind-Value="Material.Code" class="form-control" /> 
                <ValidationMessage For="() => Material.Code" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="details" class="form-label">Details:</label> 
                <InputText id="details" @bind-Value="Material.Details" class="form-control" /> 
                <ValidationMessage For="() => Material.Details" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="validfrom" class="form-label">ValidFrom:</label> 
                <InputDate id="validfrom" @bind-Value="Material.ValidFrom" class="form-control" /> 
                <ValidationMessage For="() => Material.ValidFrom" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="validto" class="form-label">ValidTo:</label> 
                <InputDate id="validto" @bind-Value="Material.ValidTo" class="form-control" /> 
                <ValidationMessage For="() => Material.ValidTo" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/materials">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Material Material { get; set; } = default!;

    protected override void OnInitialized() => Material ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddMaterial()
    {
        using var context = DbFactory.CreateDbContext();
        context.Material.Add(Material);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/materials");
    }
}
