@page "/materials/create"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Material</PageTitle>

<h1>Create Material</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <EditForm Model="Material" OnValidSubmit="AddMaterial">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Name:</label>
                <InputText @bind-Value="Material.Name" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Code:</label>
                <InputText @bind-Value="Material.Code" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Details:</label>
                <InputText @bind-Value="Material.Details" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/materials">Back to List</a>
</div>

@code {
    // The material object we are filling in.
    private Material Material { get; set; } = new();

    // Runs when the user clicks Create.
    private async Task AddMaterial()
    {
        using var context = DbFactory.CreateDbContext();
        context.Material.Add(Material);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/materials");
    }
}
