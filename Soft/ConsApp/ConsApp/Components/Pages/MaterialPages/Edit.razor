@page "/materials/edit"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Material</PageTitle>

<h1>Edit Material</h1>
<hr />

@if (material is null)
{
    <p>Loading...</p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="material" OnValidSubmit="UpdateMaterial">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="mb-3">
                    <label class="form-label">Name:</label>
                    <InputText @bind-Value="material.Name" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Code:</label>
                    <InputText @bind-Value="material.Code" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Details:</label>
                    <InputText @bind-Value="material.Details" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/materials">Back to List</a>
</div>

@code {
    // The material Id comes from the URL like /materials/edit?id=...
    [SupplyParameterFromQuery] public Guid Id { get; set; }

    // The material we are editing.
    private Material? material;

    protected override async Task OnInitializedAsync()
    {
        // Load the material from the database using the Id from the query string.
        using var context = DbFactory.CreateDbContext();
        material = await context.Material.FirstOrDefaultAsync(m => m.Id == Id);
    }

    private async Task UpdateMaterial()
    {
        if (material is null) return;

        // Save the changes back to the database.
        using var context = DbFactory.CreateDbContext();
        context.Material.Update(material);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/materials");
    }
}
