@page "/materials/details"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Material</h2>
    <hr />
    @if (material is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@material.Name</dd>
            <dt class="col-sm-2">Code</dt>
            <dd class="col-sm-10">@material.Code</dd>
            <dt class="col-sm-2">Details</dt>
            <dd class="col-sm-10">@material.Details</dd>
            <dt class="col-sm-2">ValidFrom</dt>
            <dd class="col-sm-10">@material.ValidFrom</dd>
            <dt class="col-sm-2">ValidTo</dt>
            <dd class="col-sm-10">@material.ValidTo</dd>
        </dl>
        <div>
            <a href="@($"/materials/edit?id={material.Id}")">Edit</a> |
            <a href="@($"/materials")">Back to List</a>
        </div>
    }
</div>

@code {
    private Material? material;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        material = await context.Material.FirstOrDefaultAsync(m => m.Id == Id);

        if (material is null)
        {
            NavigationManager.NotFound();
        }
    }
}
