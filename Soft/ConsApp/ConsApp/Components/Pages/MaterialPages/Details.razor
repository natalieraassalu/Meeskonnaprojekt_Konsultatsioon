@page "/materials/details"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Material Details</PageTitle>

<h1>Material Details</h1>
<hr />

@if (material is null)
{
    <p>Loading...</p>
}
else
{
    @* Show the material's data read-only. *@
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@material.Name</dd>

        <dt class="col-sm-2">Author</dt>
        <dd class="col-sm-10">@material.Author</dd>

        <dt class="col-sm-2">Number</dt>
        <dd class="col-sm-10">@material.Number</dd>

        <dt class="col-sm-2">Details</dt>
        <dd class="col-sm-10">@material.Details</dd>
    </dl>

    <a href="@($"/materials/edit?id={material.Id}")" class="btn btn-primary">Edit</a>
    <a href="/materials" class="btn btn-secondary">Back to List</a>
}

@code {
    // The material Id comes from the URL like /materials/details?id=...
    [SupplyParameterFromQuery] public Guid Id { get; set; }

    // The material we are showing.
    private Material? material;

    protected override async Task OnInitializedAsync()
    {
        // Load the material from the database.
        using var context = DbFactory.CreateDbContext();
        material = await context.Material.FirstOrDefaultAsync(m => m.Id == Id);
    }
}
