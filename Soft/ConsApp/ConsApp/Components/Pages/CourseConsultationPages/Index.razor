@page "/consultationslots"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Consultation Slots</PageTitle>

<h1>Consultation Slots</h1>

<p>
    <a href="consultationslots/create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Course</th>
            <th>Lecturer</th>
            <th>Status</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Meeting Link</th>
            <th>Is Booked</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var slot in slots)
        {
            <tr>
                <!-- Show course name instead of CourseId Guid -->
                <td>@(courses.FirstOrDefault(c => c.Id == slot.CourseId)?.Name ?? "Unknown")</td>
                <!-- Show lecturer name instead of LecturerId Guid -->
                <td>@(lecturers.FirstOrDefault(l => l.Id == slot.LecturerId)?.Name ?? "Unknown")</td>
                <!-- Show status name instead of StatusId Guid -->
                <td>@(statuses.FirstOrDefault(s => s.Id == slot.StatusId)?.Name ?? "Unknown")</td>
                <td>@slot.StartTime.ToString("g")</td>
                <td>@slot.EndTime.ToString("g")</td>
                <td>@slot.MeetingLink</td>
                <td>@slot.IsBooked</td>
                <td>
                    <a href="@($"consultationslots/edit?id={slot.Id}")">Edit</a> |
                    <a href="@($"consultationslots/details?id={slot.Id}")">Details</a> |
                    <a href="@($"consultationslots/delete?id={slot.Id}")">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    // Lists loaded from database when page opens
    private List<ConsultationSlot> slots = new();
    private List<Course> courses = new();
    private List<Lecturer> lecturers = new();
    private List<Status> statuses = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Load all slots and related data from database
        slots = await context.ConsultationSlot.ToListAsync();
        courses = await context.Course.ToListAsync();
        lecturers = await context.Lecturer.ToListAsync();
        statuses = await context.Statuses.ToListAsync();
    }
}