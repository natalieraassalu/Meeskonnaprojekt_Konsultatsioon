@page "/courses/{id:guid}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<Abc.Infra.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(course?.Name ?? "Course")</PageTitle>

@if (course is null) {
    <p><em>Loading...</em></p>
}
else {
    <h1>@course.Name</h1>
    <p>@course.Details</p>
    <hr />
    @if (successMessage != null) {
        <div class="alert alert-success">@successMessage</div>
    }
    @if (errorMessage != null) {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <h3>Available Consultation Slots</h3>

    @if (slots.Count == 0){
        <p>No available slots for this course.</p>
    }
    else{
        <table class="table">
            <thead>
                <tr>
                    <th>Lecturer</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Meeting Link</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in slots){
                    <tr>
                        <td>@(slot.Lecturer?.Name ?? "Unknown")</td>
                        <td>@slot.StartTime.ToString("g")</td>
                        <td>@slot.EndTime.ToString("g")</td>
                        <td>@slot.MeetingLink</td>
                        <td>
                            <button class="btn btn-success" @onclick="() => BookSlot(slot.Id)">Book</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">Back to Courses</a>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Course? course;
    private List<ConsultationSlot> slots = new();
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync() {
        using var context = DbFactory.CreateDbContext();
        course = await context.Courses.FirstOrDefaultAsync(c => c.Id == Id);

        if (course is null) {
            NavigationManager.NotFound();
            return;
        }

        slots = await CourseSlots(context)
            .Where(slot => !slot.IsBooked)
            .ToListAsync();
    }
    private async Task BookSlot(Guid slotId) {
        successMessage = null;
        errorMessage = null;

        using var context = DbFactory.CreateDbContext();

        var student = await GetCurrentUserAsync(context);
        if (student is null){
            errorMessage = "Please complete your profile first";
            return;
        }

        var slot = await CourseSlots(context).FirstOrDefaultAsync(slot => slot.Id == slotId);

        if (slot is null) { errorMessage = "Slot not found."; return; }
        if (slot.IsBooked) { errorMessage = "This slot was just booked by someone else."; return; }

        slot.IsBooked = true;

        context.BookingPage.Add(new BookingPage{
            CourseId = Id,
            SlotId = slotId,
            StudentId = student.Id,
            BookingDate = DateTime.Now,
            Note = string.Empty
        });

        await context.SaveChangesAsync();

        slots.RemoveAll(s => s.Id == slotId);
        successMessage = "Slot booked successfully!";
    }
    private IQueryable<ConsultationSlot> CourseSlots(Abc.Infra.ApplicationDbContext context){
        var slotIds = context.CourseConsultation
            .Where(courseConsultation => courseConsultation.CourseId == Id)
            .Select(courseConsultation => courseConsultation.ConsultationSlotId);

        return context.ConsultationSlot
            .Include(slot => slot.Lecturer)
            .Where(slot => slotIds.Contains(slot.Id))
            .OrderBy(slot => slot.StartTime);
    }
    private async Task<Abc.Data.Consultation.User?> GetCurrentUserAsync(Abc.Infra.ApplicationDbContext context){
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;

        if (string.IsNullOrEmpty(email)) return null;

        return await context.User.FirstOrDefaultAsync(user => user.Email == email);
    }
}
