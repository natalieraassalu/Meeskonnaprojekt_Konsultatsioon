@page "/courses/{id:guid}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(course?.Name ?? "Course")</PageTitle>

@if (course is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <h1>@course.Name</h1>
    <p>@course.Details</p>
    <hr />

    @if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <h3>Available Consultation Slots</h3>

    @if (slots.Count == 0)
    {
        <p>No available slots for this course.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Lecturer</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Meeting Link</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in slots)
                {
                    <tr>
                        <td>@(users.FirstOrDefault(u => u.Id == slot.LecturerId)?.Name ?? "Unknown")</td>
                        <td>@slot.StartTime.ToString("g")</td>
                        <td>@slot.EndTime.ToString("g")</td>
                        <td>@slot.MeetingLink</td>
                        <td>
                            <button class="btn btn-success" @onclick="() => BookSlot(slot.Id)">Book</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">Back to Courses</a>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Course? course;
    private List<ConsultationSlot> slots = new();
    private List<Abc.Data.Consultation.User> users = new();
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        course = await context.Course.FirstOrDefaultAsync(c => c.Id == Id);

        if (course is null)
        {
            NavigationManager.NotFound();
            return;
        }

        // Load only available slots linked to this course.
        slots = await (
            from courseConsultation in context.CourseConsultation
            join slot in context.ConsultationSlot
                on courseConsultation.ConsultationSlotId equals slot.Id
            where courseConsultation.CourseId == Id && !slot.IsBooked
            orderby slot.StartTime
            select slot)
            .ToListAsync();

        users = await context.User.ToListAsync();
    }

    private async Task BookSlot(Guid slotId)
    {
        successMessage = null;
        errorMessage = null;

        using var context = DbFactory.CreateDbContext();

        // Get the logged-in user's email from the authentication state.
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;

        // Find the matching User record by email so we can set StudentId.
        var student = string.IsNullOrEmpty(email)
            ? null
            : await context.User.FirstOrDefaultAsync(u => u.Email == email);

        if (student is null)
        {
            errorMessage = "Please complete your profile first";
            return;
        }

        var slot = await (
            from courseConsultation in context.CourseConsultation
            join consultationSlot in context.ConsultationSlot
                on courseConsultation.ConsultationSlotId equals consultationSlot.Id
            where courseConsultation.CourseId == Id && consultationSlot.Id == slotId
            select consultationSlot)
            .FirstOrDefaultAsync();

        if (slot is null) { errorMessage = "Slot not found."; return; }
        if (slot.IsBooked) { errorMessage = "This slot was just booked by someone else."; return; }

        slot.IsBooked = true;
        context.ConsultationSlot.Update(slot);

        var booking = new BookingPage
        {
            SlotId = slotId,
            // Tie the booking to the logged-in student so the FK is satisfied.
            StudentId = student.Id,
            BookingDate = DateTime.Now,
            Note = string.Empty
        };
        context.BookingPage.Add(booking);

        await context.SaveChangesAsync();

        slots.RemoveAll(s => s.Id == slotId);
        successMessage = "Slot booked successfully!";
    }
}
