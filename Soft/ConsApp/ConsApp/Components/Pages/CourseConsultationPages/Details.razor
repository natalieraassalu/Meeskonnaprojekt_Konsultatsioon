@page "/courseconsultations/details"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>CourseConsultation</h2>
    <hr />
    @if (courseconsultation is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">CourseId</dt>
            <dd class="col-sm-10">@courseconsultation.CourseId</dd>
            <dt class="col-sm-2">ConsultationSlotId</dt>
            <dd class="col-sm-10">@courseconsultation.ConsultationSlotId</dd>
            <dt class="col-sm-2">ValidFrom</dt>
            <dd class="col-sm-10">@courseconsultation.ValidFrom</dd>
            <dt class="col-sm-2">ValidTo</dt>
            <dd class="col-sm-10">@courseconsultation.ValidTo</dd>
        </dl>
        <div>
            <a href="@($"/courseconsultations/edit?id={courseconsultation.Id}")">Edit</a> |
            <a href="@($"/courseconsultations")">Back to List</a>
        </div>
    }
</div>

@code {
    private CourseConsultation? courseconsultation;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        courseconsultation = await context.CourseConsultation.FirstOrDefaultAsync(m => m.Id == Id);

        if (courseconsultation is null)
        {
            NavigationManager.NotFound();
        }
    }
}
