@page "/courseconsultations/delete"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>CourseConsultation</h2>
    <hr />
    @if (courseconsultation is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">CourseId</dt>
            <dd class="col-sm-10">@courseconsultation.CourseId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ConsultationSlotId</dt>
            <dd class="col-sm-10">@courseconsultation.ConsultationSlotId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ValidFrom</dt>
            <dd class="col-sm-10">@courseconsultation.ValidFrom</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ValidTo</dt>
            <dd class="col-sm-10">@courseconsultation.ValidTo</dd>
        </dl>
        <EditForm method="post" Model="courseconsultation" OnValidSubmit="DeleteCourseConsultation" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(courseconsultation is null)">Delete</button> |
            <a href="/courseconsultations">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private CourseConsultation? courseconsultation;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        courseconsultation = await context.CourseConsultation.FirstOrDefaultAsync(m => m.Id == Id);

        if (courseconsultation is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteCourseConsultation()
    {
        using var context = DbFactory.CreateDbContext();
        context.CourseConsultation.Remove(courseconsultation!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/courseconsultations");
    }
}
