@page "/coursematerials/edit"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>CourseMaterial</h2>
<hr />
@if (CourseMaterial is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="CourseMaterial" OnValidSubmit="UpdateCourseMaterial" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="CourseMaterial.Id" value="@CourseMaterial.Id" />
                <div class="mb-3">
                    <label for="courseid" class="form-label">CourseId:</label>
                    <input id="courseid" @bind="CourseMaterial.CourseId" class="form-control" type="text" />
                    <ValidationMessage For="() => CourseMaterial.CourseId" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="materialid" class="form-label">MaterialId:</label>
                    <input id="materialid" @bind="CourseMaterial.MaterialId" class="form-control" type="text" />
                    <ValidationMessage For="() => CourseMaterial.MaterialId" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="validfrom" class="form-label">ValidFrom:</label>
                    <InputDate id="validfrom" @bind-Value="CourseMaterial.ValidFrom" class="form-control" />
                    <ValidationMessage For="() => CourseMaterial.ValidFrom" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="validto" class="form-label">ValidTo:</label>
                    <InputDate id="validto" @bind-Value="CourseMaterial.ValidTo" class="form-control" />
                    <ValidationMessage For="() => CourseMaterial.ValidTo" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/coursematerials">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    [SupplyParameterFromForm]
    private CourseMaterial? CourseMaterial { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        CourseMaterial ??= await context.CourseMaterial.FirstOrDefaultAsync(m => m.Id == Id);

        if (CourseMaterial is null)
        {
            NavigationManager.NotFound();
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateCourseMaterial()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(CourseMaterial!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!CourseMaterialExists(CourseMaterial!.Id))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/coursematerials");
    }

    private bool CourseMaterialExists(Guid id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.CourseMaterial.Any(e => e.Id == id);
    }
}
