@page "/coursematerials/delete"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>CourseMaterial</h2>
    <hr />
    @if (coursematerial is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">CourseId</dt>
            <dd class="col-sm-10">@coursematerial.CourseId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">MaterialId</dt>
            <dd class="col-sm-10">@coursematerial.MaterialId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ValidFrom</dt>
            <dd class="col-sm-10">@coursematerial.ValidFrom</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ValidTo</dt>
            <dd class="col-sm-10">@coursematerial.ValidTo</dd>
        </dl>
        <EditForm method="post" Model="coursematerial" OnValidSubmit="DeleteCourseMaterial" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(coursematerial is null)">Delete</button> |
            <a href="/coursematerials">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private CourseMaterial? coursematerial;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        coursematerial = await context.CourseMaterial.FirstOrDefaultAsync(m => m.Id == Id);

        if (coursematerial is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteCourseMaterial()
    {
        using var context = DbFactory.CreateDbContext();
        context.CourseMaterial.Remove(coursematerial!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/coursematerials");
    }
}
