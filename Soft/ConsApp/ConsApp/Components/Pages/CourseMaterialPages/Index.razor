@page "/coursematerials"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Course Materials</PageTitle>

<h1>Course Materials</h1>

<p>
    <a href="coursematerials/create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Course</th>
            <th>Material</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cm in courseMaterials)
        {
            <tr>
                <td>@cm.Course?.Name</td>
                <td>@cm.Material?.Name</td>
                <td>
                    <a href="@($"coursematerials/edit?id={cm.Id}")">Edit</a> |
                    <a href="@($"coursematerials/details?id={cm.Id}")">Details</a> |
                    <a href="@($"coursematerials/delete?id={cm.Id}")">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<CourseMaterial> courseMaterials = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        courseMaterials = await context.CourseMaterial.Include(cm => cm.Course).Include(cm => cm.Material).ToListAsync();
    }
}
