@page "/coursematerials/create"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Course Material</PageTitle>

<h1>Create Course Material</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <EditForm Model="CourseMaterial" OnValidSubmit="AddCourseMaterial">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Course:</label>
                <InputSelect @bind-Value="CourseMaterial.CourseId" class="form-control">
                    <option value="">-- select course --</option>
                    @* Loop through all courses and show their name. *@
                    @foreach (var course in courses)
                    {
                        <option value="@course.Id">@course.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Material:</label>
                <InputSelect @bind-Value="CourseMaterial.MaterialId" class="form-control">
                    <option value="">-- select material --</option>
                    @* Loop through all materials and show their name. *@
                    @foreach (var material in materials)
                    {
                        <option value="@material.Id">@material.Name</option>
                    }
                </InputSelect>
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/coursematerials">Back to List</a>
</div>

@code {
    // The course material object we are filling in.
    private CourseMaterial CourseMaterial { get; set; } = new();

    // Lists used to fill the dropdowns.
    private List<Course> courses = new();
    private List<Material> materials = new();

    protected override async Task OnInitializedAsync()
    {
        // Load all courses and materials from the database for the dropdowns.
        using var context = DbFactory.CreateDbContext();
        courses = await context.Course.ToListAsync();
        materials = await context.Material.ToListAsync();
    }

    private async Task AddCourseMaterial()
    {
        using var context = DbFactory.CreateDbContext();
        context.CourseMaterial.Add(CourseMaterial);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/coursematerials");
    }
}
