@page "/myslots/{courseId:guid}"
@* Stay on the server, don't move to the browser *@
@* TODO: Once roles are done, verify this course belongs to logged-in lecturer *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<Abc.Infra.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Manage Slots</PageTitle>

@if (course is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <h1>@course.Name � Consultation Slots</h1>
    <hr />

    @if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <h3>Existing Slots</h3>

    @if (slots.Count == 0)
    {
        <p>No slots yet for this course.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Meeting Link</th>
                    <th>Is Booked</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in slots)
                {
                    <tr>
                        <td>@slot.StartTime.ToString("g")</td>
                        <td>@slot.EndTime.ToString("g")</td>
                        <td>@slot.MeetingLink</td>
                        <td>@slot.IsBooked</td>
                        <td>
                            <!-- Lecturer can cancel a slot -->
                            @if (!slot.IsBooked)
                            {
                                <button class="btn btn-danger" @onclick="() => DeleteSlot(slot.Id)">Delete</button>
                            }
                            else
                            {
                                <span class="text-muted">Booked</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h3 class="mt-4">Add New Slot</h3>
    <div class="row">
        <div class="col-md-4">
            <!-- Simple form to add a new slot directly on this page -->
            <div class="mb-3">
                <label class="form-label">Start Time:</label>
                <input type="datetime-local" class="form-control" @bind="newStartTime" />
            </div>
            <div class="mb-3">
                <label class="form-label">End Time:</label>
                <input type="datetime-local" class="form-control" @bind="newEndTime" />
            </div>
            <div class="mb-3">
                <label class="form-label">Meeting Link:</label>
                <input type="text" class="form-control" @bind="newMeetingLink" />
            </div>
            <div class="mb-3">
                <label class="form-label">Also add to another course:</label>
                <InputSelect class="form-control" @bind-Value="selectedOtherCourseId">
                    <option value="@Guid.Empty">-- only this course --</option>
                    @foreach (var otherCourse in otherCourses)
                    {
                        <option value="@otherCourse.Id">@otherCourse.Name</option>
                    }
                </InputSelect>
            </div>
            <button class="btn btn-success" @onclick="AddSlot">Add Slot</button>
        </div>
    </div>
}

<div class="mt-3">
    <a href="/mycourses" class="btn btn-secondary">Back to My Courses</a>
</div>

@code {
    // courseId comes from the URL e.g. /myslots/some-guid
    [Parameter]
    public Guid CourseId { get; set; }

    private Course? course;
    private List<ConsultationSlot> slots = new();
    private List<Course> otherCourses = new();

    // Fields for the add slot form
    private DateTime newStartTime = DateTime.Now;
    private DateTime newEndTime = DateTime.Now.AddHours(1);
    private string newMeetingLink = string.Empty;
    private Guid selectedOtherCourseId = Guid.Empty;

    // The logged-in user's domain User.Id - used as the LecturerId on new slots.
    private Guid loggedInUserId = Guid.Empty;

    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        using var context = DbFactory.CreateDbContext();

        // Load the course
        course = await context.Courses.FirstOrDefaultAsync(c => c.Id == CourseId);

        if (course is null)
        {
            NavigationManager.NotFound();
            return;
        }

        // Load only slots linked to this course.
        slots = await (
            from courseConsultation in context.CourseConsultation
            join slot in context.ConsultationSlot
                on courseConsultation.ConsultationSlotId equals slot.Id
            where courseConsultation.CourseId == CourseId
            orderby slot.StartTime
            select slot)
            .ToListAsync();

        // Look up the logged-in user's domain User row by email so we can use their Id as LecturerId.
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;
        if (!string.IsNullOrEmpty(email))
        {
            var user = await context.User.FirstOrDefaultAsync(u => u.Email == email);
            if (user is not null)
            {
                loggedInUserId = user.Id;
            }
        }

        await LoadOtherCourses(context);
    }

    private async Task LoadOtherCourses(Abc.Infra.ApplicationDbContext context)
    {
        if (loggedInUserId == Guid.Empty)
        {
            otherCourses.Clear();
            return;
        }

        // Use the same course list logic as My Courses, but leave out the current course.
        var courseIds = await context.CourseSelector
            .Where(courseSelector => courseSelector.StudentId == loggedInUserId)
            .Select(courseSelector => courseSelector.CourseId)
            .ToListAsync();

        otherCourses = await context.Courses
            .Where(otherCourse => courseIds.Contains(otherCourse.Id) && otherCourse.Id != CourseId)
            .OrderBy(otherCourse => otherCourse.Name)
            .ToListAsync();
    }

    // Runs when lecturer clicks "Add Slot"
    private async Task AddSlot()
    {
        successMessage = null;
        errorMessage = null;

        // Make sure we found the logged-in user - otherwise we can't set the lecturer.
        if (loggedInUserId == Guid.Empty)
        {
            errorMessage = "Could not find your user account. Please log in again.";
            return;
        }

        using var context = DbFactory.CreateDbContext();

        var slot = new ConsultationSlot
        {
            // The logged-in user is the lecturer for this slot.
            LecturerId = loggedInUserId,
            StartTime = newStartTime,
            EndTime = newEndTime,
            MeetingLink = newMeetingLink,
            IsBooked = false
        };

        context.ConsultationSlot.Add(slot);
        context.CourseConsultation.Add(new CourseConsultation
        {
            CourseId = CourseId,
            ConsultationSlotId = slot.Id
        });

        if (selectedOtherCourseId != Guid.Empty)
        {
            context.CourseConsultation.Add(new CourseConsultation
            {
                CourseId = selectedOtherCourseId,
                ConsultationSlotId = slot.Id
            });
        }

        await context.SaveChangesAsync();

        // Reset the form
        newStartTime = DateTime.Now;
        newEndTime = DateTime.Now.AddHours(1);
        newMeetingLink = string.Empty;
        selectedOtherCourseId = Guid.Empty;

        successMessage = "Slot added successfully!";

        // Reload slots list
        await LoadData();
    }

    // Runs when lecturer clicks Delete on a slot
    private async Task DeleteSlot(Guid slotId)
    {
        using var context = DbFactory.CreateDbContext();

        var slot = await context.ConsultationSlot.FirstOrDefaultAsync(s => s.Id == slotId);

        if (slot is null) return;

        var links = await context.CourseConsultation
            .Where(courseConsultation => courseConsultation.ConsultationSlotId == slotId)
            .ToListAsync();

        context.CourseConsultation.RemoveRange(links);
        context.ConsultationSlot.Remove(slot);
        await context.SaveChangesAsync();

        successMessage = "Slot deleted.";
        await LoadData();
    }
}
