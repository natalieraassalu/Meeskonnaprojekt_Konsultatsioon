@page "/myslots/{courseId:guid}"
@* Stay on the server, don't move to the browser *@
@* TODO: Once roles are done, verify this course belongs to logged-in lecturer *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Manage Slots</PageTitle>

@if (course is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <h1>@course.Name � Consultation Slots</h1>
    <hr />

    @if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <h3>Existing Slots</h3>

    @if (slots.Count == 0)
    {
        <p>No slots yet for this course.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Meeting Link</th>
                    <th>Is Booked</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in slots)
                {
                    <tr>
                        <td>@slot.StartTime.ToString("g")</td>
                        <td>@slot.EndTime.ToString("g")</td>
                        <td>@slot.MeetingLink</td>
                        <td>@slot.IsBooked</td>
                        <td>
                            <!-- Lecturer can cancel a slot -->
                            @if (!slot.IsBooked)
                            {
                                <button class="btn btn-danger" @onclick="() => DeleteSlot(slot.Id)">Delete</button>
                            }
                            else
                            {
                                <span class="text-muted">Booked</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h3 class="mt-4">Add New Slot</h3>
    <div class="row">
        <div class="col-md-4">
            <!-- Simple form to add a new slot directly on this page -->
            <div class="mb-3">
                <label class="form-label">Start Time:</label>
                <input type="datetime-local" class="form-control" @bind="newStartTime" />
            </div>
            <div class="mb-3">
                <label class="form-label">End Time:</label>
                <input type="datetime-local" class="form-control" @bind="newEndTime" />
            </div>
            <div class="mb-3">
                <label class="form-label">Meeting Link:</label>
                <input type="text" class="form-control" @bind="newMeetingLink" />
            </div>
            <div class="mb-3">
                <label class="form-label">Lecturer:</label>
                <select class="form-control" @bind="newLecturerId">
                    <option value="">-- Pick a lecturer --</option>
                    @foreach (var lecturer in lecturers)
                    {
                        <option value="@lecturer.Id">@lecturer.Name</option>
                    }
                </select>
            </div>
            <button class="btn btn-success" @onclick="AddSlot">Add Slot</button>
        </div>
    </div>
}

<div class="mt-3">
    <a href="/mycourses" class="btn btn-secondary">Back to My Courses</a>
</div>

@code {
    // courseId comes from the URL e.g. /myslots/some-guid
    [Parameter]
    public Guid CourseId { get; set; }

    private Course? course;
    private List<ConsultationSlot> slots = new();
    private List<Abc.Data.Consultation.User> lecturers = new();

    // Fields for the add slot form
    private DateTime newStartTime = DateTime.Now;
    private DateTime newEndTime = DateTime.Now.AddHours(1);
    private string newMeetingLink = string.Empty;
    private Guid newLecturerId;

    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        using var context = DbFactory.CreateDbContext();

        // Load the course
        course = await context.Course.FirstOrDefaultAsync(c => c.Id == CourseId);

        if (course is null)
        {
            NavigationManager.NotFound();
            return;
        }

        // Load only slots linked to this course.
        slots = await (
            from courseConsultation in context.CourseConsultation
            join slot in context.ConsultationSlot
                on courseConsultation.ConsultationSlotId equals slot.Id
            where courseConsultation.CourseId == CourseId
            orderby slot.StartTime
            select slot)
            .ToListAsync();

        lecturers = await context.User.ToListAsync();
    }

    // Runs when lecturer clicks "Add Slot"
    private async Task AddSlot()
    {
        successMessage = null;
        errorMessage = null;

        if (newLecturerId == Guid.Empty)
        {
            errorMessage = "Please select a lecturer.";
            return;
        }

        using var context = DbFactory.CreateDbContext();

        var slot = new ConsultationSlot
        {
            
            LecturerId = newLecturerId,
            StartTime = newStartTime,
            EndTime = newEndTime,
            MeetingLink = newMeetingLink,
            IsBooked = false
        };

        context.ConsultationSlot.Add(slot);
        context.CourseConsultation.Add(new CourseConsultation
        {
            CourseId = CourseId,
            ConsultationSlotId = slot.Id
        });
        await context.SaveChangesAsync();

        // Reset the form
        newStartTime = DateTime.Now;
        newEndTime = DateTime.Now.AddHours(1);
        newMeetingLink = string.Empty;
        newLecturerId = Guid.Empty;

        successMessage = "Slot added successfully!";

        // Reload slots list
        await LoadData();
    }

    // Runs when lecturer clicks Delete on a slot
    private async Task DeleteSlot(Guid slotId)
    {
        using var context = DbFactory.CreateDbContext();

        var slot = await context.ConsultationSlot.FirstOrDefaultAsync(s => s.Id == slotId);

        if (slot is null) return;

        var links = await context.CourseConsultation
            .Where(courseConsultation => courseConsultation.ConsultationSlotId == slotId)
            .ToListAsync();

        context.CourseConsultation.RemoveRange(links);
        context.ConsultationSlot.Remove(slot);
        await context.SaveChangesAsync();

        successMessage = "Slot deleted.";
        await LoadData();
    }
}
