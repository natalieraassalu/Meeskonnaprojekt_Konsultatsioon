@page "/notifications"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Notifications</PageTitle>

<h1>Notifications</h1>

<p>
    <a href="notifications/create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>ConsultationSlotId</th>
            <th>LecturerId</th>
            <th>StudentId</th>
            <th>Message</th>
            <th>SentAt</th>
            <th>Status</th>
            <th>ValidFrom</th>
            <th>ValidTo</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var notification in notifications)
        {
            <tr>
                <td>@notification.ConsultationSlotId</td>
                <td>@notification.LecturerId</td>
                <td>@notification.StudentId</td>
                <td>@notification.Message</td>
                <td>@notification.SentAt</td>
                <td>@notification.Status</td>
                <td>@notification.ValidFrom</td>
                <td>@notification.ValidTo</td>
                <td>
                    <a href="@($"notifications/edit?id={notification.Id}")">Edit</a> |
                    <a href="@($"notifications/details?id={notification.Id}")">Details</a> |
                    <a href="@($"notifications/delete?id={notification.Id}")">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Notification> notifications = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        notifications = await context.Notification.ToListAsync();
    }
}
