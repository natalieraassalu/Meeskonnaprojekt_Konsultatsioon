@page "/courseselectors"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Course Selectors</PageTitle>

<h1>Course Selectors</h1>

<p>
    <a href="courseselectors/create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Course</th>
            <th>Lecturer</th>
            <th>Student</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var selector in selectors)
        {
            <tr>
                <!-- Show course name instead of CourseId Guid -->
                <td>@(courses.FirstOrDefault(c => c.Id == selector.CourseId)?.Name ?? "Unknown")</td>

                <!-- Show lecturer name instead of LecturerId Guid -->
                <td>@(lecturers.FirstOrDefault(l => l.Id == selector.LecturerId)?.Name ?? "Unknown")</td>

                <!-- Show student name instead of StudentId Guid -->
                <td>@(students.FirstOrDefault(s => s.Id == selector.StudentId)?.Name ?? "Unknown")</td>

                <td>
                    <a href="@($"courseselectors/edit?id={selector.Id}")">Edit</a> |
                    <a href="@($"courseselectors/details?id={selector.Id}")">Details</a> |
                    <a href="@($"courseselectors/delete?id={selector.Id}")">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    // Lists loaded from database when page opens
    private List<CourseSelector> selectors = new();
    private List<Course> courses = new();
    private List<Lecturer> lecturers = new();
    private List<Student> students = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Load all selectors and related data
        selectors = await context.CourseSelector.ToListAsync();
        courses = await context.Course.ToListAsync();
        lecturers = await context.Lecturer.ToListAsync();
        students = await context.Student.ToListAsync();
    }
}