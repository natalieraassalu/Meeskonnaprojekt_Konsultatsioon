@page "/courseselectors"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Course Selectors</PageTitle>

<h1>Course Selectors</h1>

<p>
    <a href="courseselectors/create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Course</th>
            <th>Lecturer</th>
            <th>Student</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cs in courseselectors)
        {
            <tr>
                @* Look up each related row by Id and show the Name. *@
                <td>@(courses.FirstOrDefault(c => c.Id == cs.CourseId)?.Name ?? "(unknown)")</td>
                <td>@(users.FirstOrDefault(u => u.Id == cs.LecturerId)?.Name ?? "(unknown)")</td>
                <td>@(users.FirstOrDefault(u => u.Id == cs.StudentId)?.Name ?? "(unknown)")</td>
                <td>
                    <a href="@($"courseselectors/edit?id={cs.Id}")">Edit</a> |
                    <a href="@($"courseselectors/details?id={cs.Id}")">Details</a> |
                    <a href="@($"courseselectors/delete?id={cs.Id}")">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<CourseSelector> courseselectors = new();

    // Loaded once so we can resolve Guids to names without one query per row.
    private List<Course> courses = new();
    private List<User> users = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Load the course selectors plus the lookup data for names.
        courseselectors = await context.CourseSelector.ToListAsync();
        courses = await context.Course.ToListAsync();
        users = await context.User.ToListAsync();
    }
}
