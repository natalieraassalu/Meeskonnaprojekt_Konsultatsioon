@page "/courseselectors/create"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>CourseSelector</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="CourseSelector" OnValidSubmit="AddCourseSelector" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <label for="courseid" class="form-label">CourseId:</label>
                <input id="courseid" type="text" @bind="CourseSelector.CourseId" class="form-control" />
                <ValidationMessage For="() => CourseSelector.CourseId" class="text-danger" />
            </div>
            <div class="mb-3">
                <label for="lecturerid" class="form-label">LecturerId:</label>
                <input id="lecturerid" type="text" @bind="CourseSelector.LecturerId" class="form-control" />
                <ValidationMessage For="() => CourseSelector.LecturerId" class="text-danger" />
            </div>
            <div class="mb-3">
                <label for="studentid" class="form-label">StudentId:</label>
                <input id="studentid" type="text" @bind="CourseSelector.StudentId" class="form-control" />
                <ValidationMessage For="() => CourseSelector.StudentId" class="text-danger" />
            </div>        
            <div class="mb-3">
                <label for="validfrom" class="form-label">ValidFrom:</label> 
                <InputDate id="validfrom" @bind-Value="CourseSelector.ValidFrom" class="form-control" /> 
                <ValidationMessage For="() => CourseSelector.ValidFrom" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="validto" class="form-label">ValidTo:</label> 
                <InputDate id="validto" @bind-Value="CourseSelector.ValidTo" class="form-control" /> 
                <ValidationMessage For="() => CourseSelector.ValidTo" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/courseselectors">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private CourseSelector CourseSelector { get; set; } = default!;

    protected override void OnInitialized() => CourseSelector ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddCourseSelector()
    {
        using var context = DbFactory.CreateDbContext();
        context.CourseSelector.Add(CourseSelector);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/courseselectors");
    }
}
