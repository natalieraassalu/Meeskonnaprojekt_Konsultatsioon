@page "/courseselector/create"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Course</PageTitle>

<h1>Create Course</h1>
<hr />

<EditForm Model="course" OnValidSubmit="CreateCourse">
    <div class="mb-3">
        <label for="name" class="form-label">Name:</label>
        <InputText id="name" @bind-Value="course.Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label for="code" class="form-label">Code:</label>
        <InputText id="code" @bind-Value="course.Code" class="form-control" />
    </div>

    <div class="mb-3">
        <label for="details" class="form-label">Details:</label>
        <InputText id="details" @bind-Value="course.Details" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
</EditForm>

<div class="mt-3">
    <a href="/courseselector">Back to Course Selector</a>
</div>

@code {
    private Course course = new();

    private async Task CreateCourse()
    {
        using var context = DbFactory.CreateDbContext();

        context.Course.Add(course);
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/courseselector");
    }
}
