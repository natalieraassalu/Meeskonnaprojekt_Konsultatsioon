@page "/courseselectors/create"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Course Selector</PageTitle>

<h1>Create Course Selector</h1>
<hr />

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row">
    <div class="col-md-4">
        <EditForm Model="CourseSelector" OnValidSubmit="AddCourseSelector">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <!-- Dropdown to pick a course -->
            <div class="mb-3">
                <label class="form-label">Select Course:</label>
                <select class="form-control" @bind="CourseSelector.CourseId">
                    <option value="">-- Pick a course --</option>
                    @foreach (var course in courses)
                    {
                        <option value="@course.Id">@course.Name</option>
                    }
                </select>
            </div>

            <!-- Dropdown to pick a lecturer -->
            <div class="mb-3">
                <label class="form-label">Select Lecturer:</label>
                <select class="form-control" @bind="CourseSelector.LecturerId">
                    <option value="">-- Pick a lecturer --</option>
                    @foreach (var lecturer in lecturers)
                    {
                        <option value="@lecturer.Id">@lecturer.Name</option>
                    }
                </select>
            </div>

            <!-- Dropdown to pick a student -->
            <div class="mb-3">
                <label class="form-label">Select Student:</label>
                <select class="form-control" @bind="CourseSelector.StudentId">
                    <option value="">-- Pick a student --</option>
                    @foreach (var student in students)
                    {
                        <option value="@student.Id">@student.Name</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/courseselectors">Back to List</a>
</div>

@code {
    // The course selector object we are filling in
    private CourseSelector CourseSelector { get; set; } = new();

    // Lists for the dropdowns
    private List<Course> courses = new();
    private List<Lecturer> lecturers = new();
    private List<Student> students = new();

    // Error message shown if something goes wrong
    private string? errorMessage;

    // Runs when page loads - fills the dropdowns
    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        courses = await context.Course.ToListAsync();
        lecturers = await context.Lecturer.ToListAsync();
        students = await context.Student.ToListAsync();
    }

    // Runs when user clicks Create
    private async Task AddCourseSelector()
    {
        using var context = DbFactory.CreateDbContext();
        context.CourseSelector.Add(CourseSelector);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/courseselectors");
    }
}