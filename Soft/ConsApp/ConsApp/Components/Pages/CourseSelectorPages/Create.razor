@page "/courseselectors/create"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Enroll Students</PageTitle>

<h1>Enroll Students</h1>
<p>Pick a course and a lecturer, then tick the students to enroll.</p>
<hr />

<EditForm Model="this" OnValidSubmit="AddCourseSelector">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" role="alert" />

    @* Show an error if the lecturer didn't choose a course/lecturer/student. *@
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="mb-3">
        <label for="courseid" class="form-label">Course:</label>
        <InputSelect id="courseid" @bind-Value="courseId" class="form-control">
            <option value="@Guid.Empty">-- select course --</option>
            @* Loop through all courses and show their name. *@
            @foreach (var course in courses)
            {
                <option value="@course.Id">@course.Name</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label for="lecturerid" class="form-label">Lecturer:</label>
        <InputSelect id="lecturerid" @bind-Value="lecturerId" class="form-control">
            <option value="@Guid.Empty">-- select lecturer --</option>
            @* Only users with the "Lecturer" role appear here. *@
            @foreach (var lecturer in lecturers)
            {
                <option value="@lecturer.Id">@lecturer.Name</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label class="form-label">Students:</label>
        @if (students.Count == 0)
        {
            <p>No students found.</p>
        }
        else
        {
            @* One checkbox per student so the lecturer can tick many at once. *@
            @foreach (var student in students)
            {
                <div class="form-check">
                    <input type="checkbox" class="form-check-input"
                           id="student-@student.Id"
                           checked="@selectedStudentIds.Contains(student.Id)"
                           @onchange="e => ToggleStudent(student.Id, (bool)e.Value!)" />
                    <label class="form-check-label" for="student-@student.Id">@student.Name</label>
                </div>
            }
        }
    </div>

    <button type="submit" class="btn btn-primary">Enroll Selected Students</button>
</EditForm>

<div class="mt-3">
    <a href="/courseselectors">Back to List</a>
</div>

@code {
    // Selected values from the form.
    private Guid courseId = Guid.Empty;
    private Guid lecturerId = Guid.Empty;
    private HashSet<Guid> selectedStudentIds = new();

    // Lists used to fill the dropdowns and checkbox list.
    private List<Course> courses = new();
    private List<User> lecturers = new();
    private List<User> students = new();

    // Error message shown when input is invalid.
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Load all courses for the dropdown.
        courses = await context.Course.ToListAsync();

        // Load only users with role "Lecturer" by joining User -> UserRole -> Role.
        lecturers = await (
            from u in context.User
            join ur in context.UserRole on u.Id equals ur.UserId
            join r in context.Role on ur.RoleId equals r.Id
            where r.Name == "Lecturer"
            select u).ToListAsync();

        // Load only users with role "Student" the same way.
        students = await (
            from u in context.User
            join ur in context.UserRole on u.Id equals ur.UserId
            join r in context.Role on ur.RoleId equals r.Id
            where r.Name == "Student"
            select u).ToListAsync();
    }

    // Add or remove a student id from the selected set when the checkbox is toggled.
    private void ToggleStudent(Guid studentId, bool isChecked)
    {
        if (isChecked) selectedStudentIds.Add(studentId);
        else selectedStudentIds.Remove(studentId);
    }

    private async Task AddCourseSelector()
    {
        errorMessage = string.Empty;

        // Make sure the lecturer picked a course, a lecturer, and at least one student.
        if (courseId == Guid.Empty || lecturerId == Guid.Empty || selectedStudentIds.Count == 0)
        {
            errorMessage = "Please choose a course, a lecturer, and at least one student.";
            return;
        }

        using var context = DbFactory.CreateDbContext();

        // Create one CourseSelector row per selected student.
        foreach (var studentId in selectedStudentIds)
        {
            context.CourseSelector.Add(new CourseSelector
            {
                CourseId = courseId,
                LecturerId = lecturerId,
                StudentId = studentId
            });
        }

        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/courseselectors");
    }
}
