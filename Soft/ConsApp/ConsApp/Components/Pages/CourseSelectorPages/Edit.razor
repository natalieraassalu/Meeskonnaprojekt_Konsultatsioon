@page "/courseselectors/edit"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Course Selector</PageTitle>

<h1>Edit Course Selector</h1>
<hr />

@if (CourseSelector is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="CourseSelector" OnValidSubmit="UpdateCourseSelector">
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />

                <!-- Dropdown to pick a course - preselects current value -->
                <div class="mb-3">
                    <label class="form-label">Select Course:</label>
                    <select class="form-control" @bind="CourseSelector.CourseId">
                        <option value="">-- Pick a course --</option>
                        @foreach (var course in courses)
                        {
                            <option value="@course.Id">@course.Name</option>
                        }
                    </select>
                </div>

                <!-- Dropdown to pick a lecturer - preselects current value -->
                <div class="mb-3">
                    <label class="form-label">Select Lecturer:</label>
                    <select class="form-control" @bind="CourseSelector.LecturerId">
                        <option value="">-- Pick a lecturer --</option>
                        @foreach (var lecturer in lecturers)
                        {
                            <option value="@lecturer.Id">@lecturer.Name</option>
                        }
                    </select>
                </div>

                <!-- Dropdown to pick a student - preselects current value -->
                <div class="mb-3">
                    <label class="form-label">Select Student:</label>
                    <select class="form-control" @bind="CourseSelector.StudentId">
                        <option value="">-- Pick a student --</option>
                        @foreach (var student in students)
                        {
                            <option value="@student.Id">@student.Name</option>
                        }
                    </select>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/courseselectors">Back to List</a>
</div>

@code {
    // Id comes from the URL e.g. /courseselectors/edit?id=...
    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    // The course selector we are editing
    private CourseSelector? CourseSelector { get; set; }

    // Lists for the dropdowns
    private List<Course> courses = new();
    private List<Lecturer> lecturers = new();
    private List<Student> students = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Load the course selector we want to edit
        CourseSelector = await context.CourseSelector.FirstOrDefaultAsync(m => m.Id == Id);

        // If not found, go to not found page
        if (CourseSelector is null)
        {
            NavigationManager.NotFound();
            return;
        }

        // Load dropdowns
        courses = await context.Course.ToListAsync();
        lecturers = await context.Lecturer.ToListAsync();
        students = await context.Student.ToListAsync();
    }

    // Runs when user clicks Save
    private async Task UpdateCourseSelector()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(CourseSelector!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!CourseSelectorExists(CourseSelector!.Id))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/courseselectors");
    }

    // Checks if course selector still exists in database
    private bool CourseSelectorExists(Guid id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.CourseSelector.Any(e => e.Id == id);
    }
}