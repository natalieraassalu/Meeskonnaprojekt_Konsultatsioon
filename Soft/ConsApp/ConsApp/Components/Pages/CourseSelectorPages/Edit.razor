@page "/courseselectors/edit"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>CourseSelector</h2>
<hr />
@if (CourseSelector is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="CourseSelector" OnValidSubmit="UpdateCourseSelector" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="CourseSelector.Id" value="@CourseSelector.Id" />
                <div class="mb-3">
                    <label for="courseid" class="form-label">CourseId:</label>
                    <input id="courseid" type="text" @bind="CourseSelector.CourseId" class="form-control" />
                    <ValidationMessage For="() => CourseSelector.CourseId" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="lecturerid" class="form-label">LecturerId:</label>
                    <input id="lecturerid" type="text" @bind="CourseSelector.LecturerId" class="form-control" />
                    <ValidationMessage For="() => CourseSelector.LecturerId" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="studentid" class="form-label">StudentId:</label>
                    <input id="studentid" type="text" @bind="CourseSelector.StudentId" class="form-control" />
                    <ValidationMessage For="() => CourseSelector.StudentId" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="validfrom" class="form-label">ValidFrom:</label>
                    <InputDate id="validfrom" @bind-Value="CourseSelector.ValidFrom" class="form-control" />
                    <ValidationMessage For="() => CourseSelector.ValidFrom" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="validto" class="form-label">ValidTo:</label>
                    <InputDate id="validto" @bind-Value="CourseSelector.ValidTo" class="form-control" />
                    <ValidationMessage For="() => CourseSelector.ValidTo" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/courseselectors">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    [SupplyParameterFromForm]
    private CourseSelector? CourseSelector { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        CourseSelector ??= await context.CourseSelector.FirstOrDefaultAsync(m => m.Id == Id);

        if (CourseSelector is null)
        {
            NavigationManager.NotFound();
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateCourseSelector()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(CourseSelector!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!CourseSelectorExists(CourseSelector!.Id))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/courseselectors");
    }

    private bool CourseSelectorExists(Guid id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.CourseSelector.Any(e => e.Id == id);
    }
}
