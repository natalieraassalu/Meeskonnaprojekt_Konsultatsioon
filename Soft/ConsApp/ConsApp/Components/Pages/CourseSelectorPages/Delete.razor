@page "/courseselectors/delete"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>CourseSelector</h2>
    <hr />
    @if (courseselector is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">CourseId</dt>
            <dd class="col-sm-10">@courseselector.CourseId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">LecturerId</dt>
            <dd class="col-sm-10">@courseselector.LecturerId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">StudentId</dt>
            <dd class="col-sm-10">@courseselector.StudentId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ValidFrom</dt>
            <dd class="col-sm-10">@courseselector.ValidFrom</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ValidTo</dt>
            <dd class="col-sm-10">@courseselector.ValidTo</dd>
        </dl>
        <EditForm method="post" Model="courseselector" OnValidSubmit="DeleteCourseSelector" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(courseselector is null)">Delete</button> |
            <a href="/courseselectors">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private CourseSelector? courseselector;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        courseselector = await context.CourseSelector.FirstOrDefaultAsync(m => m.Id == Id);

        if (courseselector is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteCourseSelector()
    {
        using var context = DbFactory.CreateDbContext();
        context.CourseSelector.Remove(courseselector!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/courseselectors");
    }
}
