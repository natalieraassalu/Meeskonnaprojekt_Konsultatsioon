@page "/courseselector"
@namespace Abc.Soft.ConsApp.Components.Pages
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@using CourseSelectorEntity = Abc.Data.Consultation.CourseSelector
@inject IDbContextFactory<Abc.Infra.ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Course Selector</PageTitle>

<h1>Course Selector</h1>
<p>Select a course and add it to My Courses.</p>
<hr />

@if (!string.IsNullOrEmpty(message)) {
    <div class="alert alert-info">@message</div>
}

@if (courses.Count == 0) {
    <p>No available courses.</p>
}
else {
    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Search</label>
            <input class="form-control" placeholder="Search by name or code" @bind="searchText" @bind:event="oninput" />
        </div>
    </div>

    var coursesToShow = GetCoursesToShow();

    @if (coursesToShow.Count == 0) {
        <p>No matching courses found.</p>
    }
    else {
        <div class="row">
            @foreach (var course in coursesToShow) {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@course.Name (@course.Code)</h5>
                            <p class="card-text">@course.Details</p>
                            <button type="button" class="btn btn-primary mt-auto" @onclick="() => AddToMyCourses(course.Id)">
                                Add to My Courses
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private Guid currentUserId;
    private List<Course> courses = new();
    private string searchText = "";
    private string message = string.Empty;

    protected override async Task OnInitializedAsync() {
        using var context = DbFactory.CreateDbContext();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;

        currentUserId = await context.User
            .Where(user => user.Email == email)
            .Select(user => user.Id)
            .FirstAsync();

        await LoadCourses();
    }

    private async Task LoadCourses() {
        using var context = DbFactory.CreateDbContext();

        var selectedCourseIds = await context.CourseSelector
            .Where(cs => cs.StudentId == currentUserId)
            .Select(cs => cs.CourseId)
            .ToListAsync();

        courses = await context.Courses
            .Where(course => !selectedCourseIds.Contains(course.Id))
            .OrderBy(course => course.Name)
            .ToListAsync();
    }

    private async Task AddToMyCourses(Guid courseId) {
        using var context = DbFactory.CreateDbContext();

        context.CourseSelector.Add(new CourseSelectorEntity {
            CourseId = courseId,
            StudentId = currentUserId,
            LecturerId = currentUserId
        });

        await context.SaveChangesAsync();

        message = "Course added to My Courses.";
        await LoadCourses();
    }

    private List<Course> GetCoursesToShow() {
        var result = courses;

        if (!string.IsNullOrWhiteSpace(searchText)) {
            result = result.Where(course =>
                course.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                course.Code.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        return result.OrderBy(course => course.Name).ToList();
    }
}
