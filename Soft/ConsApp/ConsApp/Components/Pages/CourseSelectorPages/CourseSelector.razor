@page "/courseselector"
@namespace Abc.Soft.ConsApp.Components.Pages
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@using CourseSelectorEntity = Abc.Data.Consultation.CourseSelector
@inject IDbContextFactory<Abc.Infra.ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Course Selector</PageTitle>

<h1>Course Selector</h1>
<p>Select a course and add it to My Courses.</p>
<hr />

@if (!string.IsNullOrEmpty(message)) {
    <div class="alert alert-info">@message</div>
}

@if (courses.Count == 0) {
    <p>No available courses.</p>
}
else {
    <div class="mb-3">
        <label for="courseid" class="form-label">Course:</label>
        <InputSelect id="courseid" @bind-Value="selectedCourseId" class="form-control">
            <option value="@Guid.Empty">-- select course --</option>
            @foreach (var course in courses) {
                <option value="@course.Id">@course.Name</option>
            }
        </InputSelect>
    </div>

    <button type="button" class="btn btn-primary" @onclick="AddToMyCourses">Add to My Courses</button>
}

@code {
    private Guid currentUserId;
    private List<Course> courses = new();
    private Guid selectedCourseId = Guid.Empty;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync() {
        using var context = DbFactory.CreateDbContext();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;

        currentUserId = await context.User
            .Where(user => user.Email == email)
            .Select(user => user.Id)
            .FirstAsync();

        await LoadCourses(context);
    }

    private async Task LoadCourses(Abc.Infra.ApplicationDbContext context) {
        var selectedCourseIds = await context.CourseSelector
            .Where(cs => cs.StudentId == currentUserId)
            .Select(cs => cs.CourseId)
            .ToListAsync();

        courses = await context.Courses
            .Where(c => !selectedCourseIds.Contains(c.Id))
            .OrderBy(c => c.Name)
            .ToListAsync();
    }

    private async Task AddToMyCourses() {
        if (selectedCourseId == Guid.Empty) {
            message = "Please choose a course.";
            return;
        }

        using var context = DbFactory.CreateDbContext();

        context.CourseSelector.Add(new CourseSelectorEntity {
            CourseId = selectedCourseId,
            StudentId = currentUserId,
            LecturerId = currentUserId
        });

        await context.SaveChangesAsync();

        selectedCourseId = Guid.Empty;
        message = "Course added to My Courses.";
        await LoadCourses(context);
    }
}
