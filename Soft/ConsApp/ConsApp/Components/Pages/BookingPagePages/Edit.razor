@page "/bookingpages/edit"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>BookingPage</h2>
<hr />
@if (BookingPage is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="BookingPage" OnValidSubmit="UpdateBookingPage" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="BookingPage.Id" value="@BookingPage.Id" />
                <div class="mb-3">
                    <label for="slotid" class="form-label">SlotId:</label>
                    <input id="slotid" @bind="BookingPage.SlotId" class="form-control" type="text" />
                    <ValidationMessage For="() => BookingPage.SlotId" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="studentid" class="form-label">StudentId:</label>
                    <input id="studentid" @bind="BookingPage.StudentId" class="form-control" type="text" />
                    <ValidationMessage For="() => BookingPage.StudentId" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="bookingdate" class="form-label">BookingDate:</label>
                    <InputDate id="bookingdate" @bind-Value="BookingPage.BookingDate" class="form-control" />
                    <ValidationMessage For="() => BookingPage.BookingDate" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="note" class="form-label">Note:</label>
                    <InputText id="note" @bind-Value="BookingPage.Note" class="form-control" />
                    <ValidationMessage For="() => BookingPage.Note" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="statusid" class="form-label">StatusId:</label>
                    <input id="statusid" @bind="BookingPage.StatusId" class="form-control" type="text" />
                    <ValidationMessage For="() => BookingPage.StatusId" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="validfrom" class="form-label">ValidFrom:</label>
                    <InputDate id="validfrom" @bind-Value="BookingPage.ValidFrom" class="form-control" />
                    <ValidationMessage For="() => BookingPage.ValidFrom" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="validto" class="form-label">ValidTo:</label>
                    <InputDate id="validto" @bind-Value="BookingPage.ValidTo" class="form-control" />
                    <ValidationMessage For="() => BookingPage.ValidTo" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/bookingpages">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    [SupplyParameterFromForm]
    private BookingPage? BookingPage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        BookingPage ??= await context.BookingPage.FirstOrDefaultAsync(m => m.Id == Id);

        if (BookingPage is null)
        {
            NavigationManager.NotFound();
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateBookingPage()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(BookingPage!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!BookingPageExists(BookingPage!.Id))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/bookingpages");
    }

    private bool BookingPageExists(Guid id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.BookingPage.Any(e => e.Id == id);
    }
}
