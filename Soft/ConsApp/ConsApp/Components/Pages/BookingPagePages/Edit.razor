@page "/bookingpages/edit"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Booking</PageTitle>

<h1>Edit Booking</h1>
<hr />

@if (BookingPage is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="BookingPage" OnValidSubmit="UpdateBookingPage">
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />

                <!-- Dropdown to pick a slot - preselects current value -->
                <div class="mb-3">
                    <label class="form-label">Select Consultation Slot:</label>
                    <select class="form-control" @bind="BookingPage.SlotId">
                        <option value="">-- Pick a slot --</option>
                        @foreach (var slot in slots)
                        {
                            <option value="@slot.Id">@slot.StartTime.ToString("g") - @slot.EndTime.ToString("g")</option>
                        }
                    </select>
                </div>

                <!-- Dropdown to pick a student - preselects current value -->
                <div class="mb-3">
                    <label class="form-label">Select Student:</label>
                    <select class="form-control" @bind="BookingPage.StudentId">
                        <option value="">-- Pick a student --</option>
                        @foreach (var student in students)
                        {
                            <option value="@student.Id">@student.Name</option>
                        }
                    </select>
                </div>

                <!-- Dropdown to pick a status - preselects current value -->
                <div class="mb-3">
                    <label class="form-label">Status:</label>
                    <select class="form-control" @bind="BookingPage.StatusId">
                        <option value="">-- Pick a status --</option>
                        @foreach (var status in statuses)
                        {
                            <option value="@status.Id">@status.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Booking Date:</label>
                    <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="BookingPage.BookingDate" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Note:</label>
                    <InputText @bind-Value="BookingPage.Note" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/bookingpages">Back to List</a>
</div>

@code {
    // Id comes from the URL e.g. /bookingpages/edit?id=...
    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    // The booking we are editing
    private BookingPage? BookingPage { get; set; }

    // Lists for the dropdowns
    private List<ConsultationSlot> slots = new();
    private List<Student> students = new();
    private List<Status> statuses = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Load the booking we want to edit
        BookingPage = await context.BookingPage.FirstOrDefaultAsync(m => m.Id == Id);

        // If booking not found, go to not found page
        if (BookingPage is null)
        {
            NavigationManager.NotFound();
            return;
        }

        // Load dropdowns
        slots = await context.ConsultationSlot.ToListAsync();
        students = await context.Student.ToListAsync();
        statuses = await context.Statuses.ToListAsync();
    }

    // Runs when user clicks Save
    private async Task UpdateBookingPage()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(BookingPage!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!BookingPageExists(BookingPage!.Id))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/bookingpages");
    }

    // Checks if booking still exists in database
    private bool BookingPageExists(Guid id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.BookingPage.Any(e => e.Id == id);
    }
}