@page "/bookingpages"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Bookings</PageTitle>

<h1>Bookings</h1>

<p>
    <a href="bookingpages/create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Slot</th>
            <th>Student</th>
            <th>Status</th>
            <th>Booking Date</th>
            <th>Note</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in bookings)
        {
            <tr>
                <!-- Show slot time instead of SlotId Guid -->
                @{
                    var slot = slots.FirstOrDefault(s => s.Id == booking.SlotId);
                }
                <td>@(slot != null ? $"{slot.StartTime:g} - {slot.EndTime:g}" : "Unknown")</td>

                <!-- Show student name instead of StudentId Guid -->
                <td>@(students.FirstOrDefault(s => s.Id == booking.StudentId)?.Name ?? "Unknown")</td>

                <!-- Show status name instead of StatusId Guid -->
                <td>@(statuses.FirstOrDefault(s => s.Id == booking.StatusId)?.Name ?? "Unknown")</td>

                <td>@booking.BookingDate.ToString("g")</td>
                <td>@booking.Note</td>
                <td>
                    <a href="@($"bookingpages/edit?id={booking.Id}")">Edit</a> |
                    <a href="@($"bookingpages/details?id={booking.Id}")">Details</a> |
                    <a href="@($"bookingpages/delete?id={booking.Id}")">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    // Lists loaded from database when page opens
    private List<BookingPage> bookings = new();
    private List<ConsultationSlot> slots = new();
    private List<Student> students = new();
    private List<Status> statuses = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Load all bookings and related data
        bookings = await context.BookingPage.ToListAsync();
        slots = await context.ConsultationSlot.ToListAsync();
        students = await context.Student.ToListAsync();
        statuses = await context.Statuses.ToListAsync();
    }
}