@page "/mycourses"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>My Courses</PageTitle>

<h1>My Courses</h1>
<p>Manage your courses and consultation slots.</p>
<hr />

@if (!string.IsNullOrEmpty(message))
{
    <p>@message</p>
}
else if (courses.Count == 0)
{
    <p>No courses yet. <a href="/courseselector">Add one here.</a></p>
}
else
{
    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Search</label>
            <input class="form-control" placeholder="Search by name or code" @bind="searchText" @bind:event="oninput" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Sort by</label>
            <select class="form-control" @bind="sortBy">
                <option value="Name">Name</option>
                <option value="Code">Code</option>
            </select>
        </div>
    </div>

    var coursesToShow = GetCoursesToShow();

    @if (coursesToShow.Count == 0)
    {
        <p>No matching courses found.</p>
    }
    else
    {
        <div class="row">
            @foreach (var course in coursesToShow)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@course.Name</h5>
                            <p class="card-text">@course.Details</p>
                            <div class="mt-auto">
                                <a href="/myslots/@course.Id" class="btn btn-primary">Manage Slots</a>
                                <a href="/courses/edit?id=@course.Id" class="btn btn-secondary">Edit Course</a>
                                @* Opens the course page with announcements and materials. *@
                                <a href="/course/@course.Id" class="btn btn-info">View Course Page</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private List<Course> courses = new();
    private string searchText = "";
    private string sortBy = "Name";
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;
        var user = await context.User.FirstOrDefaultAsync(u => u.Email == email);

        if (user is null)
        {
            message = "Please log in first.";
            return;
        }

        var courseIds = await context.CourseSelector
            .Where(cs => cs.StudentId == user.Id)
            .Select(cs => cs.CourseId)
            .ToListAsync();

        courses = await context.Course
            .Where(c => courseIds.Contains(c.Id))
            .ToListAsync();
    }

    private List<Course> GetCoursesToShow()
    {
        var result = courses;

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            result = result.Where(course =>
                course.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                course.Code.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        if (sortBy == "Code")
        {
            return result.OrderBy(course => course.Code).ToList();
        }

        return result.OrderBy(course => course.Name).ToList();
    }
}
