@page "/courses/{id:guid}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>@(course?.Name ?? "Course")</PageTitle>

@if (course is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <h1>@course.Name</h1>
    <p>@course.Details</p>
    <hr />

    @if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <h3>Available Consultation Slots</h3>

    @if (slots.Count == 0)
    {
        <p>No available slots for this course.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Lecturer</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Meeting Link</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in slots)
                {
                    <tr>
                        <td>@(users.FirstOrDefault(u => u.Id == slot.LecturerId)?.Name ?? "Unknown")</td>
                        <td>@slot.StartTime.ToString("g")</td>
                        <td>@slot.EndTime.ToString("g")</td>
                        <td>@slot.MeetingLink</td>
                        <td>
                            <button class="btn btn-success" @onclick="() => BookSlot(slot.Id)">Book</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">Back to Courses</a>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Course? course;
    private List<ConsultationSlot> slots = new();
    private List<Abc.Data.Consultation.User> users = new();
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        course = await context.Course.FirstOrDefaultAsync(c => c.Id == Id);

        if (course is null)
        {
            NavigationManager.NotFound();
            return;
        }

        // Load all available slots
        slots = await context.ConsultationSlot
            .Where(s => s.IsBooked == false)
            .ToListAsync();

        users = await context.User.ToListAsync();
    }

    private async Task BookSlot(Guid slotId)
    {
        successMessage = null;
        errorMessage = null;

        using var context = DbFactory.CreateDbContext();

        var slot = await context.ConsultationSlot.FirstOrDefaultAsync(s => s.Id == slotId);

        if (slot is null) { errorMessage = "Slot not found."; return; }
        if (slot.IsBooked) { errorMessage = "This slot was just booked by someone else."; return; }

        slot.IsBooked = true;
        context.ConsultationSlot.Update(slot);

        var booking = new BookingPage
        {
            SlotId = slotId,
            BookingDate = DateTime.Now,
            Note = string.Empty
        };
        context.BookingPage.Add(booking);

        await context.SaveChangesAsync();

        slots.RemoveAll(s => s.Id == slotId);
        successMessage = "Slot booked successfully!";
    }
}