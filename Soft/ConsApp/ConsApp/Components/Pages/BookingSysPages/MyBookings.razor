@page "/mybookings"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<Abc.Infra.ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>My Bookings</PageTitle>

<h1>My Bookings</h1>
<hr />

@if (currentStudentId == Guid.Empty)
{
    <p>Please log in as a student to see your bookings.</p>
}
else if (bookings.Count == 0)
{
    <p>No bookings yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Course</th>
                <th>Lecturer</th>
                <th>Slot</th>
                <th>Booking Date</th>
                <th>Note</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in bookings)
            {
                var slot = slots.FirstOrDefault(s => s.Id == booking.SlotId);
                var lecturerName = slot != null ? users.FirstOrDefault(u => u.Id == slot.LecturerId)?.Name : null;
                var cc = slot != null ? courseConsultations.FirstOrDefault(x => x.ConsultationSlotId == slot.Id) : null;
                var courseName = cc != null ? courses.FirstOrDefault(c => c.Id == cc.CourseId)?.Name : null;
                <tr>
                    <td>@(courseName ?? "Unknown")</td>
                    <td>@(lecturerName ?? "Unknown")</td>
                    <td>@(slot != null ? $"{slot.StartTime:g} - {slot.EndTime:g}" : "Unknown")</td>
                    <td>@booking.BookingDate.ToString("g")</td>
                    <td>@booking.Note</td>
                    <td>
                        <button class="btn btn-danger" @onclick="() => CancelBooking(booking.Id)">Cancel</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">Back to Courses</a>
</div>

@code {
    private List<BookingPage> bookings = new();
    private List<ConsultationSlot> slots = new();
    private List<User> users = new();
    private List<CourseConsultation> courseConsultations = new();
    private List<Course> courses = new();

    // The logged-in student's User.Id, used to filter bookings.
    private Guid currentStudentId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        // Get the logged-in user's email from authentication state.
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;
        if (string.IsNullOrEmpty(email)) return;

        using var context = DbFactory.CreateDbContext();

        // Find the matching User record by email - this gives us the StudentId to filter by.
        var user = await context.User.FirstOrDefaultAsync(u => u.Email == email);
        if (user is null) return;
        currentStudentId = user.Id;

        // Only load bookings that belong to the current student.
        bookings = await context.BookingPage
            .Where(b => b.StudentId == currentStudentId)
            .ToListAsync();

        // Load slots so we can show the time range for each booking.
        slots = await context.ConsultationSlot.ToListAsync();

        // Supporting data to resolve each booking's lecturer name and course name.
        users = await context.User.ToListAsync();
        courseConsultations = await context.CourseConsultation.ToListAsync();
        courses = await context.Courses.ToListAsync();
    }

    private async Task CancelBooking(Guid bookingId)
    {
        using var context = DbFactory.CreateDbContext();

        var booking = await context.BookingPage.FirstOrDefaultAsync(b => b.Id == bookingId);
        if (booking is null) return;

        // Free up the slot so other students can book it.
        var slot = await context.ConsultationSlot.FirstOrDefaultAsync(s => s.Id == booking.SlotId);
        if (slot != null)
        {
            slot.IsBooked = false;
            context.ConsultationSlot.Update(slot);
        }

        context.BookingPage.Remove(booking);
        await context.SaveChangesAsync();
        await LoadData();
    }

    // Helper method: returns the logged-in user's role name ("Lecturer", "Student" or null).
    private async Task<string?> GetUserRoleAsync()
    {
        // Get the current authentication state to read the user's email.
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;
        if (string.IsNullOrEmpty(email)) return null;

        using var context = DbFactory.CreateDbContext();

        // Find the matching User record by email.
        var user = await context.User.FirstOrDefaultAsync(u => u.Email == email);
        if (user is null) return null;

        // Look up the user's role by joining UserRole with Role.
        var userRole = await context.UserRole
            .Include(ur => ur.Role)
            .FirstOrDefaultAsync(ur => ur.UserId == user.Id);

        return userRole?.Role?.Name;
    }
}
