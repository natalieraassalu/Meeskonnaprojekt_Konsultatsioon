@page "/course/{CourseId:guid}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<Abc.Infra.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(course?.Name ?? "Course")</PageTitle>

@if (course is null)
{
    <p>Loading...</p>
}
else
{
    @* Course title with Name and Code. *@
    <h2>@course.Name (@course.Code)</h2>
    <hr />

    @* =========================== Announcements =========================== *@
    <h3>Announcements</h3>

    @if (isLecturer)
    {
        @* Add Post form - only lecturers see this. *@
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Add Post</h5>
                <div class="mb-2">
                    <label class="form-label">Title</label>
                    <input class="form-control" @bind="newPostTitle" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Body</label>
                    <textarea class="form-control" rows="3" @bind="newPostBody"></textarea>
                </div>
                <button class="btn btn-primary" @onclick="AddPost">Add Post</button>
            </div>
        </div>
    }

    @if (posts.Count == 0)
    {
        <p>No announcements yet.</p>
    }
    else
    {
        @foreach (var post in posts)
        {
            <div class="card mb-2">
                <div class="card-body">
                    @if (isLecturer && editingPostId == post.Id)
                    {
                        @* Inline edit form for the post being edited. *@
                        <div class="mb-2">
                            <label class="form-label">Title</label>
                            <input class="form-control" @bind="editingTitle" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Body</label>
                            <textarea class="form-control" rows="3" @bind="editingBody"></textarea>
                        </div>
                        <button class="btn btn-primary btn-sm" @onclick="SavePostEdit">Save</button>
                        <button class="btn btn-secondary btn-sm" @onclick="CancelPostEdit">Cancel</button>
                    }
                    else
                    {
                        @* Read-only view of the post. *@
                        <h5 class="card-title">@post.Title</h5>
                        <p class="card-text">@post.Body</p>
                        <small class="text-muted">Posted @post.PostedAt.ToString("g")</small>

                        @if (isLecturer)
                        {
                            @* Lecturer-only Edit / Delete buttons. *@
                            <div class="mt-2">
                                <button class="btn btn-secondary btn-sm" @onclick="() => StartEditPost(post)">Edit</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeletePost(post.Id)">Delete</button>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    }

    <hr />

    @* =========================== Materials =========================== *@
    <h3>Materials</h3>

    @if (isLecturer)
    {
        @* Add Material form - only lecturers see this. *@
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Add Material</h5>
                <div class="mb-2">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="newMaterialName" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Link / URL</label>
                    <input class="form-control" @bind="newMaterialUrl" />
                </div>
                <button class="btn btn-primary" @onclick="AddMaterial">Add Material</button>
            </div>
        </div>
    }

    @if (materials.Count == 0)
    {
        <p>No materials yet.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var item in materials)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        @* If the material has a URL in Details, show it as a link. *@
                        @if (!string.IsNullOrWhiteSpace(item.material.Details))
                        {
                            <a href="@item.material.Details" target="_blank">@item.material.Name</a>
                        }
                        else
                        {
                            @item.material.Name
                        }
                    </div>
                    @if (isLecturer)
                    {
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteMaterial(item.link.Id)">Delete</button>
                    }
                </li>
            }
        </ul>
    }

    @if (isLecturer)
    {
        <hr />

        @* =========================== Enrolled Students =========================== *@
        <h3>Enrolled Students</h3>

        @if (enrolledStudents.Count == 0)
        {
            <p>No students enrolled yet.</p>
        }
        else
        {
            var studentsToShow = GetEnrolledStudentsToShow();

            <div class="d-flex justify-content-end mb-2">
                <input class="form-control" style="max-width: 260px;" placeholder="Search students" @bind="studentSearchText" @bind:event="oninput" />
            </div>

            @if (studentsToShow.Count == 0)
            {
                <p>No matching students found.</p>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in studentsToShow)
                        {
                            <tr>
                                <td>@student.Name</td>
                                <td>@student.Email</td>
                                <td class="text-end">
                                    <button class="btn btn-danger btn-sm" @onclick="() => RemoveStudent(student.Id)">Remove</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    }

    <div class="mt-3">
        <a href="/" class="btn btn-secondary">Back</a>
    </div>
}

@code {
    // Course Id taken from the URL.
    [Parameter] public Guid CourseId { get; set; }

    // Optional ?view=student query param lets a lecturer preview the read-only student view.
    [SupplyParameterFromQuery] public string? View { get; set; }

    // Data loaded for the page.
    private Course? course;
    private List<CoursePost> posts = new();
    private List<(CourseMaterial link, Material material)> materials = new();
    private List<User> enrolledStudents = new();

    // True only if the logged-in user has role "Lecturer".
    private bool isLecturer = false;

    // Add-Post form fields.
    private string newPostTitle = "";
    private string newPostBody = "";

    // Inline post-edit state.
    private Guid? editingPostId;
    private string editingTitle = "";
    private string editingBody = "";

    // Add-Material form fields.
    private string newMaterialName = "";
    private string newMaterialUrl = "";

    // Student search text for the lecturer-only enrolled students list.
    private string studentSearchText = "";

    protected override async Task OnInitializedAsync()
    {
        // Decide whether the current user is a lecturer (controls all forms/buttons).
        // The "?view=student" query param forces student view even for lecturers.
        isLecturer = (await GetUserRoleAsync()) == "Lecturer" && View != "student";

        // Load the course, its posts, and its materials.
        await LoadData();
    }

    private async Task LoadData()
    {
        using var context = DbFactory.CreateDbContext();

        // The course itself.
        course = await context.Courses.FirstOrDefaultAsync(c => c.Id == CourseId);

        // All announcements for this course, newest first.
        posts = await context.CoursePost
            .Where(p => p.CourseId == CourseId)
            .OrderByDescending(p => p.PostedAt)
            .ToListAsync();

        // CourseMaterial rows joined with Material rows to get names and URLs.
        var rows = await (
            from cm in context.CourseMaterials
            join m in context.Materials on cm.MaterialId equals m.Id
            where cm.CourseId == CourseId
            select new { link = cm, material = m }
        ).ToListAsync();
        materials = rows.Select(r => (r.link, r.material)).ToList();

        await LoadEnrolledStudents(context);
    }

    private async Task LoadEnrolledStudents(Abc.Infra.ApplicationDbContext context)
    {
        enrolledStudents.Clear();

        if (!isLecturer) return;

        // Load each enrolled student's user details from CourseSelector.
        var courseSelectors = await context.CourseSelector
            .Where(cs => cs.CourseId == CourseId)
            .ToListAsync();

        foreach (var courseSelector in courseSelectors)
        {
            var student = await context.User.FirstOrDefaultAsync(u => u.Id == courseSelector.StudentId);
            if (student is not null && !await IsLecturerAsync(context, student.Id))
            {
                enrolledStudents.Add(student);
            }
        }
    }

    private async Task<bool> IsLecturerAsync(Abc.Infra.ApplicationDbContext context, Guid userId)
    {
        // Keep lecturers out of the enrolled students list.
        var userRole = await context.UserRole
            .Include(ur => ur.Role)
            .FirstOrDefaultAsync(ur => ur.UserId == userId);

        return userRole?.Role?.Name == "Lecturer";
    }

    // ---------- Announcements (lecturer only) ----------

    private async Task AddPost()
    {
        // Ignore empty submits.
        if (string.IsNullOrWhiteSpace(newPostTitle) && string.IsNullOrWhiteSpace(newPostBody)) return;

        using var context = DbFactory.CreateDbContext();
        context.CoursePost.Add(new CoursePost
        {
            CourseId = CourseId,
            Title = newPostTitle,
            Body = newPostBody,
            PostedAt = DateTime.Now
        });
        await context.SaveChangesAsync();

        // Clear the form and reload the list.
        newPostTitle = "";
        newPostBody = "";
        await LoadData();
    }

    private void StartEditPost(CoursePost post)
    {
        // Remember which post we're editing and copy its current values into the form.
        editingPostId = post.Id;
        editingTitle = post.Title;
        editingBody = post.Body;
    }

    private void CancelPostEdit()
    {
        editingPostId = null;
        editingTitle = "";
        editingBody = "";
    }

    private async Task SavePostEdit()
    {
        if (editingPostId is null) return;

        using var context = DbFactory.CreateDbContext();
        var post = await context.CoursePost.FirstOrDefaultAsync(p => p.Id == editingPostId);
        if (post is null) { CancelPostEdit(); return; }

        post.Title = editingTitle;
        post.Body = editingBody;
        await context.SaveChangesAsync();

        CancelPostEdit();
        await LoadData();
    }

    private async Task DeletePost(Guid postId)
    {
        using var context = DbFactory.CreateDbContext();
        var post = await context.CoursePost.FirstOrDefaultAsync(p => p.Id == postId);
        if (post is null) return;

        context.CoursePost.Remove(post);
        await context.SaveChangesAsync();
        await LoadData();
    }

    // ---------- Materials (lecturer only) ----------

    private async Task AddMaterial()
    {
        // Need at least a name to add a material.
        if (string.IsNullOrWhiteSpace(newMaterialName)) return;

        using var context = DbFactory.CreateDbContext();

        // Create a brand new Material - Name from the form, URL stored in Details.
        var material = new Material
        {
            Name = newMaterialName,
            Details = newMaterialUrl ?? ""
        };
        context.Materials.Add(material);

        // Link the new material to this course.
        context.CourseMaterials.Add(new CourseMaterial
        {
            CourseId = CourseId,
            MaterialId = material.Id
        });

        await context.SaveChangesAsync();

        // Clear the form and reload the list.
        newMaterialName = "";
        newMaterialUrl = "";
        await LoadData();
    }

    private async Task DeleteMaterial(Guid courseMaterialId)
    {
        using var context = DbFactory.CreateDbContext();
        var link = await context.CourseMaterials.FirstOrDefaultAsync(cm => cm.Id == courseMaterialId);
        if (link is null) return;

        // Just remove the link row - the Material itself stays in case other courses use it.
        context.CourseMaterials.Remove(link);
        await context.SaveChangesAsync();
        await LoadData();
    }

    // ---------- Enrolled students (lecturer only) ----------

    private async Task RemoveStudent(Guid studentId)
    {
        if (!isLecturer) return;

        using var context = DbFactory.CreateDbContext();

        // Remove this enrollment so the course disappears from the student's My Courses page.
        var enrollments = await context.CourseSelector
            .Where(cs => cs.CourseId == CourseId && cs.StudentId == studentId)
            .ToListAsync();

        if (enrollments.Count == 0) return;

        context.CourseSelector.RemoveRange(enrollments);
        await context.SaveChangesAsync();
        await LoadData();
    }

    private List<User> GetEnrolledStudentsToShow()
    {
        if (string.IsNullOrWhiteSpace(studentSearchText))
        {
            return enrolledStudents;
        }

        return enrolledStudents
            .Where(student =>
                student.Name.Contains(studentSearchText, StringComparison.OrdinalIgnoreCase) ||
                student.Email.Contains(studentSearchText, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    // ---------- Role helper (same pattern as Home / MyCourses / NavMenu) ----------

    private async Task<string?> GetUserRoleAsync()
    {
        // Get the logged-in user's email from the authentication state.
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;
        if (string.IsNullOrEmpty(email)) return null;

        using var context = DbFactory.CreateDbContext();

        // Find the matching domain User by email.
        var user = await context.User.FirstOrDefaultAsync(u => u.Email == email);
        if (user is null) return null;

        // Look up the user's role via UserRole joined with Role.
        var userRole = await context.UserRole
            .Include(ur => ur.Role)
            .FirstOrDefaultAsync(ur => ur.UserId == user.Id);

        return userRole?.Role?.Name;
    }
}
