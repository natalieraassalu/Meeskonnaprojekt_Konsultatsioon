@page "/roles/create"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Role</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Role" OnValidSubmit="AddRole" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <label for="name" class="form-label">Name:</label> 
                <InputText id="name" @bind-Value="Role.Name" class="form-control" /> 
                <ValidationMessage For="() => Role.Name" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="code" class="form-label">Code:</label> 
                <InputText id="code" @bind-Value="Role.Code" class="form-control" /> 
                <ValidationMessage For="() => Role.Code" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="details" class="form-label">Details:</label> 
                <InputText id="details" @bind-Value="Role.Details" class="form-control" /> 
                <ValidationMessage For="() => Role.Details" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="validfrom" class="form-label">ValidFrom:</label> 
                <InputDate id="validfrom" @bind-Value="Role.ValidFrom" class="form-control" /> 
                <ValidationMessage For="() => Role.ValidFrom" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="validto" class="form-label">ValidTo:</label> 
                <InputDate id="validto" @bind-Value="Role.ValidTo" class="form-control" /> 
                <ValidationMessage For="() => Role.ValidTo" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/roles">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Role Role { get; set; } = default!;

    protected override void OnInitialized() => Role ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddRole()
    {
        using var context = DbFactory.CreateDbContext();
        context.Role.Add(Role);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/roles");
    }
}
