@page "/roles/delete"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Infra
@inject IRolesRepo repo
@inject NavigationManager NavigationManager

<PageTitle>Delete Role</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>

<div>
    <h2>Role</h2>
    <hr />

    @if (role is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@role.Name</dd>
        </dl>

        <EditForm method="post" Model="role" OnValidSubmit="DeleteRole" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger">Delete</button> |
            <a href="/roles">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Role? role;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        role = await repo.GetAsync(Id);

        if (role is null)
        {
            NavigationManager.NavigateTo("/notfound");
        }
    }

    private async Task DeleteRole()
    {
        await repo.DeleteAsync(Id);
        NavigationManager.NavigateTo("/roles");
    }
}