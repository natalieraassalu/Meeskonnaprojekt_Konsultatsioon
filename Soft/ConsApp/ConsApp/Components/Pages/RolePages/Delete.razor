@page "/roles/delete"
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.EntityFrameworkCore
@using ConsApp.Data
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Role</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>

<div>
    <h2>Role</h2>
    <hr />

    @if (role is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@role.Name</dd>
        </dl>

        <EditForm method="post" Model="role" OnValidSubmit="DeleteRole" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger">Delete</button> |
            <a href="/roles">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Role? role;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        role = await context.Role.FirstOrDefaultAsync(m => m.Id == Id);

        if (role is null)
        {
            NavigationManager.NavigateTo("/notfound");
        }
    }

    private async Task DeleteRole()
    {
        using var context = DbFactory.CreateDbContext();

        var roleToDelete = await context.Role.FirstOrDefaultAsync(x => x.Id == Id);

        if (roleToDelete is not null)
        {
            context.Role.Remove(roleToDelete);
            await context.SaveChangesAsync();
        }

        NavigationManager.NavigateTo("/roles");
    }
}