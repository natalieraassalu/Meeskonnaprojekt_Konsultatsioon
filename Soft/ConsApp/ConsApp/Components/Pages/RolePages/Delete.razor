@page "/roles/delete"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Role</h2>
    <hr />
    @if (role is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@role.Name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Code</dt>
            <dd class="col-sm-10">@role.Code</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Details</dt>
            <dd class="col-sm-10">@role.Details</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ValidFrom</dt>
            <dd class="col-sm-10">@role.ValidFrom</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ValidTo</dt>
            <dd class="col-sm-10">@role.ValidTo</dd>
        </dl>
        <EditForm method="post" Model="role" OnValidSubmit="DeleteRole" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(role is null)">Delete</button> |
            <a href="/roles">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Role? role;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        role = await context.Role.FirstOrDefaultAsync(m => m.Id == Id);

        if (role is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteRole()
    {
        using var context = DbFactory.CreateDbContext();
        context.Role.Remove(role!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/roles");
    }
}
