@page "/roles"
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.AspNetCore.Components.QuickGrid
@using Abc.Infra
@inject IRolesRepo repo

<PageTitle>Roles</PageTitle>

<h1>Roles</h1>

<p>
    <a href="roles/create">Create New</a>
</p>

<QuickGrid Class="table" Items="roles">
    <PropertyColumn Title="Name" Property="role => role.Name" />

    <TemplateColumn Context="role">
        <a href="@($"roles/edit?id={role.Id}")">Edit</a> |
        <a href="@($"roles/details?id={role.Id}")">Details</a> |
        <a href="@($"roles/delete?id={role.Id}")">Delete</a>
    </TemplateColumn>
</QuickGrid>

@code {
    private IQueryable<Role> roles = Enumerable.Empty<Role>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        var result = await repo.GetAsync(new Query());
        roles = result.AsQueryable();
    }

}