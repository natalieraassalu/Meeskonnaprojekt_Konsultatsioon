@page "/roles/details"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Role</h2>
    <hr />
    @if (role is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@role.Name</dd>
            <dt class="col-sm-2">Code</dt>
            <dd class="col-sm-10">@role.Code</dd>
            <dt class="col-sm-2">Details</dt>
            <dd class="col-sm-10">@role.Details</dd>
            <dt class="col-sm-2">ValidFrom</dt>
            <dd class="col-sm-10">@role.ValidFrom</dd>
            <dt class="col-sm-2">ValidTo</dt>
            <dd class="col-sm-10">@role.ValidTo</dd>
        </dl>
        <div>
            <a href="@($"/roles/edit?id={role.Id}")">Edit</a> |
            <a href="@($"/roles")">Back to List</a>
        </div>
    }
</div>

@code {
    private Role? role;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        role = await context.Role.FirstOrDefaultAsync(m => m.Id == Id);

        if (role is null)
        {
            NavigationManager.NotFound();
        }
    }
}
