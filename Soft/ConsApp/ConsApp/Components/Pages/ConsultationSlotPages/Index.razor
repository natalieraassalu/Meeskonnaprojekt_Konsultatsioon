@page "/consultationslots"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Consultation Slots</PageTitle>

<h1>Consultation Slots</h1>

<p>
    <a href="consultationslots/create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Course</th>
            <th>Lecturer</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Meeting Link</th>
            <th>Is Booked</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var slot in slots)
        {
            <tr>
                <td>@GetCourseNames(slot.Id)</td>
                <!-- Show user name instead of LecturerId Guid -->
                <td>@(users.FirstOrDefault(u => u.Id == slot.LecturerId)?.Name ?? "Unknown")</td>
                <td>@slot.StartTime.ToString("g")</td>
                <td>@slot.EndTime.ToString("g")</td>
                <td>@slot.MeetingLink</td>
                <td>@slot.IsBooked</td>
                <td>
                    <a href="@($"consultationslots/edit?id={slot.Id}")">Edit</a> |
                    <a href="@($"consultationslots/details?id={slot.Id}")">Details</a> |
                    <a href="@($"consultationslots/delete?id={slot.Id}")">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<ConsultationSlot> slots = new();
    private List<Abc.Data.Consultation.User> users = new();
    private List<Course> courses = new();
    private List<CourseConsultation> courseConsultations = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        slots = await context.ConsultationSlot.OrderBy(slot => slot.StartTime).ToListAsync();
        users = await context.User.ToListAsync();
        courses = await context.Course.ToListAsync();
        courseConsultations = await context.CourseConsultation.ToListAsync();
    }

    private string GetCourseNames(Guid slotId)
    {
        var courseIds = courseConsultations
            .Where(courseConsultation => courseConsultation.ConsultationSlotId == slotId)
            .Select(courseConsultation => courseConsultation.CourseId)
            .ToList();

        var names = courses
            .Where(course => courseIds.Contains(course.Id))
            .Select(course => course.Name)
            .ToList();

        return names.Count == 0 ? "Unassigned" : string.Join(", ", names);
    }
}
