@page "/consultationslots/edit"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Consultation Slot</PageTitle>

<h1>Edit Consultation Slot</h1>
<hr />

@if (ConsultationSlot is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="ConsultationSlot" OnValidSubmit="UpdateConsultationSlot">
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />

                <!-- Dropdown to pick a course - preselects current value -->
                <div class="mb-3">
                    <label class="form-label">Select Course:</label>
                    <select class="form-control" @bind="ConsultationSlot.CourseId">
                        <option value="">-- Pick a course --</option>
                        @foreach (var course in courses)
                        {
                            <option value="@course.Id">@course.Name</option>
                        }
                    </select>
                </div>

                <!-- Dropdown to pick a lecturer - preselects current value -->
                <div class="mb-3">
                    <label class="form-label">Select Lecturer:</label>
                    <select class="form-control" @bind="ConsultationSlot.LecturerId">
                        <option value="">-- Pick a lecturer --</option>
                        @foreach (var lecturer in lecturers)
                        {
                            <option value="@lecturer.Id">@lecturer.Name</option>
                        }
                    </select>
                </div>

                <!-- Dropdown to pick a status - preselects current value -->
                <div class="mb-3">
                    <label class="form-label">Status:</label>
                    <select class="form-control" @bind="ConsultationSlot.StatusId">
                        <option value="">-- Pick a status --</option>
                        @foreach (var status in statuses)
                        {
                            <option value="@status.Id">@status.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Start Time:</label>
                    <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="ConsultationSlot.StartTime" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">End Time:</label>
                    <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="ConsultationSlot.EndTime" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Meeting Link:</label>
                    <InputText @bind-Value="ConsultationSlot.MeetingLink" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Is Booked:</label>
                    <InputCheckbox @bind-Value="ConsultationSlot.IsBooked" class="form-check-input" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/consultationslots">Back to List</a>
</div>

@code {
    // Id comes from the URL e.g. /consultationslots/edit?id=...
    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    // The slot we are editing
    private ConsultationSlot? ConsultationSlot { get; set; }

    // Lists for the dropdowns
    private List<Course> courses = new();
    private List<Lecturer> lecturers = new();
    private List<Status> statuses = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Load the slot we want to edit
        ConsultationSlot = await context.ConsultationSlot.FirstOrDefaultAsync(m => m.Id == Id);

        // If slot not found, go to not found page
        if (ConsultationSlot is null)
        {
            NavigationManager.NotFound();
            return;
        }

        // Load dropdowns
        courses = await context.Course.ToListAsync();
        lecturers = await context.Lecturer.ToListAsync();
        statuses = await context.Statuses.ToListAsync();
    }

    // Runs when user clicks Save
    private async Task UpdateConsultationSlot()
    {
        using var context = DbFactory.CreateDbContext();

        // Attach tells EF Core this object already exists in the database and needs updating
        context.Attach(ConsultationSlot!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            // If slot was deleted by someone else while we were editing, go to not found
            if (!ConsultationSlotExists(ConsultationSlot!.Id))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/consultationslots");
    }

    // Checks if a slot with this id still exists in the database
    private bool ConsultationSlotExists(Guid id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.ConsultationSlot.Any(e => e.Id == id);
    }
}