@page "/consultationslots/create"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>ConsultationSlot</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="ConsultationSlot" OnValidSubmit="AddConsultationSlot" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="mb-3">
                <label for="courseid" class="form-label">Course:</label>
                <InputSelect id="courseid" @bind-Value="CourseId" class="form-control">
                    <option value="@Guid.Empty">-- select course --</option>
                    @foreach (var course in courses)
                    {
                        <option value="@course.Id">@course.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label for="lecturerid" class="form-label">Lecturer:</label>
                <InputSelect id="lecturerid" @bind-Value="ConsultationSlot.LecturerId" class="form-control">
                    <option value="@Guid.Empty">-- select lecturer --</option>
                    @* Loop through all users and show their name as a lecturer option. *@
                    @foreach (var user in users)
                    {
                        <option value="@user.Id">@user.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => ConsultationSlot.LecturerId" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="starttime" class="form-label">StartTime:</label>
                @* datetime-local input lets the user pick both date and time. *@
                <input id="starttime" type="datetime-local" @bind="ConsultationSlot.StartTime" class="form-control" />
                <ValidationMessage For="() => ConsultationSlot.StartTime" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="endtime" class="form-label">EndTime:</label>
                <input id="endtime" type="datetime-local" @bind="ConsultationSlot.EndTime" class="form-control" />
                <ValidationMessage For="() => ConsultationSlot.EndTime" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="meetinglink" class="form-label">MeetingLink:</label>
                <InputText id="meetinglink" @bind-Value="ConsultationSlot.MeetingLink" class="form-control" />
                <ValidationMessage For="() => ConsultationSlot.MeetingLink" class="text-danger" />
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/consultationslots">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private ConsultationSlot ConsultationSlot { get; set; } = new();

    [SupplyParameterFromForm]
    private Guid CourseId { get; set; }

    // List of users used to fill the lecturer dropdown.
    private List<User> users = [];
    private List<Course> courses = [];
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        ConsultationSlot ??= new();

        // A new slot is never booked on creation.
        ConsultationSlot.IsBooked = false;

        // Set helpful default times so the form is not blank.
        if (ConsultationSlot.StartTime == default)
        {
            ConsultationSlot.StartTime = DateTime.Now;
            ConsultationSlot.EndTime = DateTime.Now.AddHours(1);
        }

        // Load all users from the database for the lecturer dropdown.
        using var context = DbFactory.CreateDbContext();
        users = await context.User.ToListAsync();
        courses = await context.Course.OrderBy(course => course.Name).ToListAsync();
    }

    private async Task AddConsultationSlot()
    {
        errorMessage = null;

        if (CourseId == Guid.Empty)
        {
            errorMessage = "Please select a course.";
            return;
        }

        // Make sure IsBooked is false for new slots (form does not show it).
        ConsultationSlot.IsBooked = false;

        using var context = DbFactory.CreateDbContext();
        context.ConsultationSlot.Add(ConsultationSlot);
        context.CourseConsultation.Add(new CourseConsultation
        {
            CourseId = CourseId,
            ConsultationSlotId = ConsultationSlot.Id
        });
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/consultationslots");
    }
}
