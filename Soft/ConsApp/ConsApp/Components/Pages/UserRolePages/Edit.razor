@page "/userroles/edit"
@attribute [ExcludeFromInteractiveRouting]

@using Abc.Infra
@inject IUserRolesRepo userRolesRepo
@inject IUsersRepo usersRepo
@inject IRolesRepo rolesRepo
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>UserRole</h2>
<hr />

@if (UserRole is null)
{
    <p>Loading...</p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="UserRole" OnValidSubmit="UpdateUserRole" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                <input type="hidden" name="UserRole.Id" value="@UserRole.Id" />

                <div class="mb-3">
                    <label for="userid" class="form-label">User:</label>
                    <InputSelect id="userid" @bind-Value="UserRole.UserId" class="form-control">
                        <option value="@Guid.Empty">-- select user --</option>
                        @foreach (var user in users)
                        {
                            <option value="@user.Id">@user.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => UserRole.UserId" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="roleid" class="form-label">Role:</label>
                    <InputSelect id="roleid" @bind-Value="UserRole.RoleId" class="form-control">
                        <option value="@Guid.Empty">-- select role --</option>
                        @foreach (var role in roles)
                        {
                            <option value="@role.Id">@role.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => UserRole.RoleId" class="text-danger" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/userroles">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private UserRole? UserRole { get; set; }

    private List<User> users = [];
    private List<Role> roles = [];

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        users = (await usersRepo.GetAsync(new Query())).ToList();
        roles = (await rolesRepo.GetAsync(new Query())).ToList();

        UserRole ??= await userRolesRepo.GetAsync(Id);

        if (UserRole is null)
        {
            NavigationManager.NavigateTo("/notfound");
        }
    }

    private async Task UpdateUserRole()
    {
        if (UserRole is null) return;

        if (UserRole.UserId == Guid.Empty || UserRole.RoleId == Guid.Empty)
        {
            return;
        }

        await userRolesRepo.UpdateAsync(UserRole);
        NavigationManager.NavigateTo("/userroles");
    }
}