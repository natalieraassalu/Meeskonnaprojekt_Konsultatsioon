@page "/userroles/delete"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Infra
@inject IUserRolesRepo repo
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>

<div>
    <h2>UserRole</h2>
    <hr />

    @if (userrole is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">User</dt>
            <dd class="col-sm-10">@userrole.User?.Name</dd>

            <dt class="col-sm-2">Role</dt>
            <dd class="col-sm-10">@userrole.Role?.Name</dd>
        </dl>

        <EditForm method="post" Model="userrole" OnValidSubmit="DeleteUserRole" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger">Delete</button> |
            <a href="/userroles">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private UserRole? userrole;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        userrole = await repo.GetAsync(Id);

        if (userrole is null)
        {
            NavigationManager.NavigateTo("/notfound");
        }
    }

    private async Task DeleteUserRole()
    {
        await repo.DeleteAsync(Id);
        NavigationManager.NavigateTo("/userroles");
    }
}