@page "/courses/{id:guid}"
@* Stay on the server, don't move to the browser *@
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>@(course?.Name ?? "Course")</PageTitle>

@if (course is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <h1>@course.Name</h1>
    <p>@course.Details</p>
    <hr />

    @if (successMessage != null)
    {
        <!-- Show green success message after booking -->
        <div class="alert alert-success">@successMessage</div>
    }

    @if (errorMessage != null)
    {
        <!-- Show red error message if booking fails -->
        <div class="alert alert-danger">@errorMessage</div>
    }

    <h3>Available Consultation Slots</h3>

    @if (slots.Count == 0)
    {
        <p>No available slots for this course.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Lecturer</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Meeting Link</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in slots)
                {
                    <tr>
                        <!-- Show lecturer name instead of Id -->
                        <td>@(lecturers.FirstOrDefault(l => l.Id == slot.LecturerId)?.Name ?? "Unknown")</td>
                        <td>@slot.StartTime.ToString("g")</td>
                        <td>@slot.EndTime.ToString("g")</td>
                        <td>@slot.MeetingLink</td>
                        <td>
                            <!-- Book button - calls BookSlot method with this slot's Id -->
                            <button class="btn btn-success" @onclick="() => BookSlot(slot.Id)">Book</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">Back to Courses</a>
</div>

@code {
    // Id comes from the URL e.g. /courses/some-guid
    [Parameter]
    public Guid Id { get; set; }

    // The course we are viewing
    private Course? course;

    // Only unbooked slots for this course
    private List<ConsultationSlot> slots = new();

    // Lecturers list for showing names
    private List<Lecturer> lecturers = new();

    // Success and error messages shown to user
    private string? successMessage;
    private string? errorMessage;

    // Runs when page loads
    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Load the course by Id from URL
        course = await context.Course.FirstOrDefaultAsync(c => c.Id == Id);

        if (course is null)
        {
            NavigationManager.NotFound();
            return;
        }

        // Load only available (not booked) slots for this course
        slots = await context.ConsultationSlot
            .Where(s => s.CourseId == Id && s.IsBooked == false)
            .ToListAsync();

        // Load lecturers for showing names
        lecturers = await context.Lecturer.ToListAsync();
    }

    // Runs when student clicks "Book" on a slot
    private async Task BookSlot(Guid slotId)
    {
        // Clear previous messages
        successMessage = null;
        errorMessage = null;

        using var context = DbFactory.CreateDbContext();

        // Find the slot
        var slot = await context.ConsultationSlot.FirstOrDefaultAsync(s => s.Id == slotId);

        if (slot is null)
        {
            errorMessage = "Slot not found.";
            return;
        }

        // Check slot is still available
        if (slot.IsBooked)
        {
            errorMessage = "This slot was just booked by someone else. Please pick another.";
            // Refresh the slots list
            slots = await context.ConsultationSlot
                .Where(s => s.CourseId == Id && s.IsBooked == false)
                .ToListAsync();
            return;
        }

        // Mark slot as booked
        slot.IsBooked = true;
        context.ConsultationSlot.Update(slot);

        // Create a booking record
        var booking = new BookingPage
        {
            SlotId = slotId,
            BookingDate = DateTime.Now,
            Note = string.Empty
        };
        context.BookingPage.Add(booking);

        // Save both changes at the same time
        await context.SaveChangesAsync();

        // Remove the booked slot from the list so it disappears
        slots.RemoveAll(s => s.Id == slotId);

        successMessage = "Slot booked successfully!";
    }
}