@page "/courses/details"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory

<PageTitle>Course Details</PageTitle>

<h1>Course Details</h1>
<hr />

@if (course is null)
{
    <p>Loading...</p>
}
else
{
    @* Show the course's data read-only. *@
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@course.Name</dd>

        <dt class="col-sm-2">Code</dt>
        <dd class="col-sm-10">@course.Code</dd>

        <dt class="col-sm-2">Details</dt>
        <dd class="col-sm-10">@course.Details</dd>

        <dt class="col-sm-2">ValidFrom</dt>
        <dd class="col-sm-10">@course.ValidFrom.ToShortDateString()</dd>

        <dt class="col-sm-2">ValidTo</dt>
        <dd class="col-sm-10">@course.ValidTo.ToShortDateString()</dd>
    </dl>

    <a href="@($"/courses/edit?id={course.Id}")" class="btn btn-primary">Edit</a>
    <a href="/courses" class="btn btn-secondary">Back to List</a>
}

@code {
    // The course Id comes from the URL like /courses/details?id=...
    [SupplyParameterFromQuery] public Guid Id { get; set; }

    // The course we are showing.
    private Course? course;

    protected override async Task OnInitializedAsync()
    {
        // Load the course from the database.
        using var context = DbFactory.CreateDbContext();
        course = await context.Course.FirstOrDefaultAsync(c => c.Id == Id);
    }
}
