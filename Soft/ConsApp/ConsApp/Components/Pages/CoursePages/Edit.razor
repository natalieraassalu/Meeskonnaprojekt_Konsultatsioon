@page "/courses/edit"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Course</PageTitle>

<h1>Edit Course</h1>
<hr />

@if (course is null)
{
    <p>Loading...</p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="course" OnValidSubmit="UpdateCourse">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="mb-3">
                    <label class="form-label">Name:</label>
                    <InputText @bind-Value="course.Name" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Code:</label>
                    <InputText @bind-Value="course.Code" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Details:</label>
                    <InputText @bind-Value="course.Details" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/mycourses">Back to List</a>
</div>

@code {
    // The course Id comes from the URL like /courses/edit?id=...
    [SupplyParameterFromQuery] public Guid Id { get; set; }

    // The course we are editing.
    private Course? course;

    protected override async Task OnInitializedAsync()
    {
        // Load the course from the database using the Id from the query string.
        using var context = DbFactory.CreateDbContext();
        course = await context.Course.FirstOrDefaultAsync(c => c.Id == Id);
    }

    private async Task UpdateCourse()
    {
        if (course is null) return;

        // Save the changes back to the database.
        using var context = DbFactory.CreateDbContext();
        context.Course.Update(course);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/mycourses");
    }
}
