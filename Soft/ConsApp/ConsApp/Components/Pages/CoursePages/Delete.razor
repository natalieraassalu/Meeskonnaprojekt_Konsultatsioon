@page "/courses/delete"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Course</PageTitle>

<h1>Delete Course</h1>
<h3>Are you sure you want to delete this course?</h3>
<hr />

@if (course is null)
{
    <p>Loading...</p>
}
else
{
    @* Show the course's data so the user can confirm what they're deleting. *@
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@course.Name</dd>

        <dt class="col-sm-2">Code</dt>
        <dd class="col-sm-10">@course.Code</dd>

        <dt class="col-sm-2">Details</dt>
        <dd class="col-sm-10">@course.Details</dd>
    </dl>

    <button class="btn btn-danger" @onclick="DeleteCourse">Delete</button>
    <a href="/courses" class="btn btn-secondary">Cancel</a>
}

@code {
    // The course Id comes from the URL like /courses/delete?id=...
    [SupplyParameterFromQuery] public Guid Id { get; set; }

    // The course we are about to delete.
    private Course? course;

    protected override async Task OnInitializedAsync()
    {
        // Load the course from the database so we can show its data.
        using var context = DbFactory.CreateDbContext();
        course = await context.Course.FirstOrDefaultAsync(c => c.Id == Id);
    }

    private async Task DeleteCourse()
    {
        if (course is null) return;

        using var context = DbFactory.CreateDbContext();

        // Delete all student enrollments for this course first
        var selectors = await context.CourseSelector
            .Where(cs => cs.CourseId == course.Id)
            .ToListAsync();
        context.CourseSelector.RemoveRange(selectors);

        // Delete all material links for this course
        var materials = await context.CourseMaterial
            .Where(cm => cm.CourseId == course.Id)
            .ToListAsync();
        context.CourseMaterial.RemoveRange(materials);

        // Delete all announcements/posts for this course
        var posts = await context.CoursePost
            .Where(cp => cp.CourseId == course.Id)
            .ToListAsync();
        context.CoursePost.RemoveRange(posts);

        // Now it's safe to delete the course itself
        context.Course.Remove(course);

        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/courses");
    }
}