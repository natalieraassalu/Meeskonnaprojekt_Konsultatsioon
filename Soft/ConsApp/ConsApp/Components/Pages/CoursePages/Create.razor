@page "/courses/create"
@using Microsoft.EntityFrameworkCore
@using Abc.Data.Consultation
@inject IDbContextFactory<ConsApp.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Course</PageTitle>

<h1>Create Course</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <EditForm Model="Course" OnValidSubmit="AddCourse">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Name:</label>
                <InputText @bind-Value="Course.Name" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Code:</label>
                <InputText @bind-Value="Course.Code" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Details:</label>
                <InputText @bind-Value="Course.Details" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Start of Course:</label>
                <InputDate @bind-Value="Course.StartOfCourse" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">End of Course:</label>
                <InputDate @bind-Value="Course.EndOfCourse" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/courses">Back to List</a>
</div>

@code {
    // The course object we are filling in
    private Course Course { get; set; } = new();

    // Runs when user clicks Create
    private async Task AddCourse()
    {
        using var context = DbFactory.CreateDbContext();
        context.Course.Add(Course);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/courses");
    }
}