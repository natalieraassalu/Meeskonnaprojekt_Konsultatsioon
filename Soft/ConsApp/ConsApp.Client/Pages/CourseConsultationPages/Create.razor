@page "/courseconsultations/create"
@using Abc.Data.Consultation
@using Abc.Infra
@using Abc.Razor.Pages
@attribute [ExcludeFromInteractiveRouting]
@inject ICourseConsultationsRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="courseConsultation" EntityTitle="Course Consultation" BasePath="/courseconsultations" OnValidSubmit="addCourseConsultation" />

@code {
    [SupplyParameterFromForm] private CourseConsultation courseConsultation { get; set; } = default!;
    protected override void OnInitialized() => courseConsultation ??= new();
    private async Task addCourseConsultation()
    {
        await repo.CreateAsync(courseConsultation);
        NavigationManager.NavigateTo("/courseconsultations");
    }
}
