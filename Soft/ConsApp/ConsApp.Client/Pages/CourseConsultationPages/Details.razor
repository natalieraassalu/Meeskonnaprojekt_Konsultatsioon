@page "/courseconsultations/details"
@rendermode InteractiveAuto
@using Abc.Data.Consultation
@using Abc.Infra
@inject ICourseConsultationsRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage
    PageTitleText="Details Course Consultation"
    EntityTitle="Course Consultation"
    Entity="courseConsultation"
    EntityId="courseConsultation?.Id"
    BasePath="/courseconsultations" />

@code {
    private CourseConsultation courseConsultation;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync() {
        courseConsultation = await repo.GetAsync(Id);
        if (courseConsultation is null) NavigationManager.NotFound();
    }
}
