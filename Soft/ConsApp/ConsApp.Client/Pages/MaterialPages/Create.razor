@page "/materials/create"
@rendermode InteractiveAuto
@using Abc.Data.Consultation
@using Abc.Infra
@using Abc.Razor.Pages
@inject IMaterialsRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="material" EntityTitle="Material" BasePath="/materials" OnValidSubmit="addMaterial" />

@code {
    [SupplyParameterFromForm(Name = nameof(Material))] private Material material { get; set; } = default!;
    protected override void OnInitialized() => material ??= new();
    private async Task addMaterial()
    {
        await repo.CreateAsync(material);
        NavigationManager.NavigateTo("/materials");
    }
}
