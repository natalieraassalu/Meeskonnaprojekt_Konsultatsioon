@page "/users/create"
@using Abc.Data.Consultation
@using Abc.Infra
@using Abc.Razor.Pages
@attribute [ExcludeFromInteractiveRouting]
@inject IUsersRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="user" EntityTitle="User" BasePath="/users" OnValidSubmit="addUser" />

@code {
    [SupplyParameterFromForm(Name = nameof(User))] private User user { get; set; } = default!;
    protected override void OnInitialized() => user ??= new();
    private async Task addUser()
    {
        await repo.CreateAsync(user);
        NavigationManager.NavigateTo("/users");
    }
}
