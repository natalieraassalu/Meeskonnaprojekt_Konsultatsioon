@page "/users/details"
@using Abc.Data.Consultation
@using Abc.Infra
@inject IUsersRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage
    PageTitleText="Details User"
    EntityTitle="User"
    Entity="user"
    EntityId="user?.Id"
    BasePath="/users" />

@code {
    private User user;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync() {
        user = await repo.GetAsync(Id);
        if (user is null) NavigationManager.NotFound();
    }
}
