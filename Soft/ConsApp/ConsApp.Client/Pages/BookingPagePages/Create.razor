@page "/bookingpages/create"
@using Abc.Data.Consultation
@using Abc.Infra
@using Abc.Razor.Pages
@inject IBookingPagesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="bookingPage" EntityTitle="Booking Page" BasePath="/bookingpages" OnValidSubmit="addBookingPage" />

@code {
    [SupplyParameterFromForm(Name = nameof(BookingPage))] private BookingPage bookingPage { get; set; } = default!;
    protected override void OnInitialized() => bookingPage ??= new();
    private async Task addBookingPage()
    {
        await repo.CreateAsync(bookingPage);
        NavigationManager.NavigateTo("/bookingpages");
    }
}
