@page "/coursematerials/create"
@rendermode InteractiveAuto
@using Abc.Data.Consultation
@using Abc.Infra
@using Abc.Razor.Pages
@inject ICourseMaterialsRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="courseMaterial" EntityTitle="Course Material" BasePath="/coursematerials" OnValidSubmit="addCourseMaterial" />

@code {
    [SupplyParameterFromForm(Name = nameof(CourseMaterial))] private CourseMaterial courseMaterial { get; set; } = default!;
    protected override void OnInitialized() => courseMaterial ??= new();
    private async Task addCourseMaterial()
    {
        await repo.CreateAsync(courseMaterial);
        NavigationManager.NavigateTo("/coursematerials");
    }
}
