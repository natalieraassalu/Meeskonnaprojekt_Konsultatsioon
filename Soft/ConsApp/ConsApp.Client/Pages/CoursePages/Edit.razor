@page "/courses/edit"
@rendermode InteractiveAuto
@using Abc.Data.Consultation
@using Abc.Infra
@inject ICoursesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage
    PageTitleText="Edit Course"
    EntityTitle="Course"
    Entity="course"
    BasePath="/courses"
    EntityId="@Id"
    OnValidSubmit="updateCourse" />

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm(Name = nameof(Course))] private Course course { get; set; }
    protected override async Task OnInitializedAsync()
    {
        course ??= await repo.GetAsync(Id);
        if (course is null) NavigationManager.NotFound();
    }
    private async Task updateCourse()
    {
        await repo.UpdateAsync(course!);
        NavigationManager.NavigateTo("/courses");
    }
}
