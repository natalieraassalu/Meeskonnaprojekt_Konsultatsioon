@page "/courseposts/create"
@using Abc.Data.Consultation
@using Abc.Infra
@using Abc.Razor.Pages
@attribute [ExcludeFromInteractiveRouting]
@inject ICoursePostsRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="coursePost" EntityTitle="Course Post" BasePath="/courseposts" OnValidSubmit="addCoursePost" />

@code {
    [SupplyParameterFromForm(Name = nameof(CoursePost))] private CoursePost coursePost { get; set; } = default!;
    protected override void OnInitialized() => coursePost ??= new();
    private async Task addCoursePost()
    {
        await repo.CreateAsync(coursePost);
        NavigationManager.NavigateTo("/courseposts");
    }
}
