@page "/userroles/create"
@using Abc.Data.Consultation
@using Abc.Infra
@using Abc.Razor.Pages
@inject IUserRolesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="userRole" EntityTitle="User Role" BasePath="/userroles" OnValidSubmit="addUserRole" />

@code {
    [SupplyParameterFromForm(Name = nameof(UserRole))] private UserRole userRole { get; set; } = default!;
    protected override void OnInitialized() => userRole ??= new();
    private async Task addUserRole()
    {
        await repo.CreateAsync(userRole);
        NavigationManager.NavigateTo("/userroles");
    }
}
