@page "/userroles/edit"
@rendermode InteractiveAuto
@using Abc.Data.Consultation
@using Abc.Infra
@inject IUserRolesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage
    PageTitleText="Edit User Role"
    EntityTitle="User Role"
    Entity="userRole"
    BasePath="/userroles"
    EntityId="@Id"
    OnValidSubmit="updateUserRole" />

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm(Name = nameof(UserRole))] private UserRole userRole { get; set; }
    protected override async Task OnInitializedAsync()
    {
        userRole ??= await repo.GetAsync(Id);
        if (userRole is null) NavigationManager.NotFound();
    }
    private async Task updateUserRole()
    {
        await repo.UpdateAsync(userRole!);
        NavigationManager.NavigateTo("/userroles");
    }
}
