@page "/consultationslots/edit"
@using Abc.Data.Consultation
@using Abc.Infra
@inject IConsultationSlotsRepo repo
@inject NavigationManager NavigationManager

<MyEditPage
    PageTitleText="Edit Consultation Slot"
    EntityTitle="Consultation Slot"
    Entity="consultationSlot"
    BasePath="/consultationslots"
    EntityId="@Id"
    OnValidSubmit="updateConsultationSlot" />

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm(Name = nameof(ConsultationSlot))] private ConsultationSlot consultationSlot { get; set; }
    protected override async Task OnInitializedAsync()
    {
        consultationSlot ??= await repo.GetAsync(Id);
        if (consultationSlot is null) NavigationManager.NotFound();
    }
    private async Task updateConsultationSlot()
    {
        await repo.UpdateAsync(consultationSlot!);
        NavigationManager.NavigateTo("/consultationslots");
    }
}
