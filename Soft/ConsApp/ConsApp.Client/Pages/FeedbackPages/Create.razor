@page "/feedbacks/create"
@rendermode InteractiveAuto
@using Abc.Data.Consultation
@using Abc.Infra
@using Abc.Razor.Pages
@inject IFeedbacksRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="feedback" EntityTitle="Feedback" BasePath="/feedbacks" OnValidSubmit="addFeedback" />

@code {
    [SupplyParameterFromForm(Name = nameof(Feedback))] private Feedback feedback { get; set; } = default!;
    protected override void OnInitialized() => feedback ??= new();
    private async Task addFeedback()
    {
        await repo.CreateAsync(feedback);
        NavigationManager.NavigateTo("/feedbacks");
    }
}
