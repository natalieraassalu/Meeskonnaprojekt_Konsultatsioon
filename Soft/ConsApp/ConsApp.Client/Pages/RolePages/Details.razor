@page "/roles/details"
@using Abc.Data.Consultation
@using Abc.Infra
@inject IRolesRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage
    PageTitleText="Details Role"
    EntityTitle="Role"
    Entity="role"
    EntityId="role?.Id"
    BasePath="/roles" />

@code {
    private Role role;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync() {
        role = await repo.GetAsync(Id);
        if (role is null) NavigationManager.NotFound();
    }
}
