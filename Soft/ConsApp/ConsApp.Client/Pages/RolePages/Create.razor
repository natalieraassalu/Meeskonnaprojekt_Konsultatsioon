@page "/roles/create"
@rendermode InteractiveAuto
@using Abc.Data.Consultation
@using Abc.Infra
@using Abc.Razor.Pages
@inject IRolesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="role" EntityTitle="Role" BasePath="/roles" OnValidSubmit="addRole" />

@code {
    [SupplyParameterFromForm(Name = nameof(Role))] private Role role { get; set; } = default!;
    protected override void OnInitialized() => role ??= new();
    private async Task addRole()
    {
        await repo.CreateAsync(role);
        NavigationManager.NavigateTo("/roles");
    }
}
