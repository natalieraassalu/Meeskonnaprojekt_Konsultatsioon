@page "/notifications/delete"
@using Abc.Data.Consultation
@using Abc.Infra
@attribute [ExcludeFromInteractiveRouting]
@inject INotificationsRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete Notification" EntityTitle="Notification" Entity="notification" BasePath="/notifications" OnValidSubmit="deleteNotification" />

@code {
    private Notification notification;

    [SupplyParameterFromQuery] private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        notification = await repo.GetAsync(Id);
        if (notification is null) NavigationManager.NotFound();
    }

    private async Task deleteNotification()
    {
        await repo.DeleteAsync(notification.Id);
        NavigationManager.NavigateTo("/notifications");
    }
}
